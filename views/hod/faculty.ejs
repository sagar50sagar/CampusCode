            <div class="px-6 py-4 border-b border-gray-100 dark:border-gray-700 flex justify-between items-center bg-gray-50/50 dark:bg-gray-700/20">
                <h3 class="font-bold text-gray-800 dark:text-white">College-wide Teacher Search</h3>
                <button onclick="closeGlobalSearch()" class="text-gray-400 hover:text-gray-600 dark:hover:text-gray-200">
                    <i class="fas fa-times"></i>
                </button>
            </div>
            <div class="p-6">
                <div class="relative mb-6">
                    <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
                        <i class="fas fa-search text-gray-400"></i>
                    </div>
                    <input type="text" id="globalTeacherSearchInput" 
                        class="block w-full pl-10 pr-4 py-3 border border-gray-200 dark:border-gray-600 rounded-xl focus:ring-2 focus:ring-primary-500 bg-white dark:bg-gray-800 text-sm text-gray-900 dark:text-white placeholder-gray-400 transition-shadow"
                        placeholder="Search by name or email across all departments...">
                </div>
                
                <div id="globalSearchResults" class="space-y-2 max-h-96 overflow-y-auto">
                    <p class="text-center text-gray-500 py-8 italic">Start typing to search teachers...</p>
                </div>
            </div>
        </div>
    </div>

    <!-- Unified Assignment Modal -->
    <div id="unifiedModal" class="fixed inset-0 z-[70] flex items-center justify-center bg-black/60 backdrop-blur-sm hidden">
        <div class="bg-white dark:bg-gray-800 w-full max-w-lg rounded-3xl shadow-2xl overflow-hidden animate-[fadeIn_0.2s_ease-out]">
            <div class="px-8 py-6 border-b border-gray-100 dark:border-gray-700 flex justify-between items-center bg-gray-50/50 dark:bg-gray-700/20">
                <div>
                    <h3 class="text-xl font-bold text-gray-800 dark:text-white">Unified Assignment Console</h3>
                    <p class="text-xs text-gray-500" id="modalTargetName"></p>
                </div>
                <button onclick="closeUnifiedModal()" class="text-gray-400 hover:text-gray-600 dark:hover:text-gray-200">
                    <i class="fas fa-times text-xl"></i>
                </button>
            </div>
            
            <div class="p-8">
                <div class="flex gap-4 mb-6 border-b border-gray-100 dark:border-gray-700 pb-px">
                    <button id="tab-promote" onclick="showTab('promote')" class="pb-3 text-sm font-bold border-b-2 border-primary-500 text-primary-600 transition-all">Role & Promotion</button>
                    <button id="tab-assign" onclick="showTab('assign')" class="pb-3 text-sm font-medium text-gray-500 border-b-2 border-transparent hover:text-gray-700 transition-all">Subject Assignment</button>
                </div>

                <div id="content-promote" class="space-y-6">
                    <form id="promoteForm" class="space-y-4">
                        <input type="hidden" name="id" id="promoteUserId">
                        <div>
                            <label class="block text-xs font-bold text-gray-400 uppercase tracking-widest mb-2">Designated Role</label>
                            <select id="roleSelect" name="role" onchange="togglePromoSubject()" class="w-full rounded-xl border-gray-200 dark:border-gray-700 bg-gray-50 dark:bg-gray-900 text-sm p-3 focus:ring-2 focus:ring-primary-500">
                                <option value="faculty">Faculty Member</option>
                                <option value="hos">Head of Studies (HOS)</option>
                            </select>
                        </div>
                        <div id="promoSubjectContainer" class="hidden">
                            <label class="block text-xs font-bold text-gray-400 uppercase tracking-widest mb-2">Assign Master Subject</label>
                            <select name="subject" id="promoSubject" class="w-full rounded-xl border-gray-200 dark:border-gray-700 bg-gray-50 dark:bg-gray-900 text-sm p-3 focus:ring-2 focus:ring-primary-500">
                                <option value="">Select a Subject...</option>
                                <% dropdownData.subjects.forEach(s => { %>
                                    <option value="<%= s %>"><%= s %></option>
                                <% }) %>
                            </select>
                            <p class="mt-2 text-[10px] text-primary-500 font-medium italic"><i class="fas fa-magic mr-1"></i> Promotion to HOS triggers automated bulk-assignment for every section of this subject.</p>
                        </div>
                        <div class="pt-6">
                            <button type="submit" class="w-full py-3 bg-primary-600 hover:bg-primary-700 text-white rounded-xl font-bold shadow-lg transition-all active:scale-95">Update Primary Role</button>
                        </div>
                    </form>
                </div>

                <div id="content-assign" class="hidden space-y-6">
                    <form id="assignForm" class="space-y-4">
                        <input type="hidden" name="facultyId" id="assignUserId">
                        <div>
                            <label class="block text-xs font-bold text-gray-400 uppercase tracking-widest mb-2">Select Subject</label>
                            <select name="subjectName" id="mainSubjectSelect" onchange="handleSubjectChange()" class="w-full rounded-xl border-gray-200 dark:border-gray-700 bg-gray-50 dark:bg-gray-900 text-sm p-3 focus:ring-2 focus:ring-primary-500">
                                <option value="">Choose Subject</option>
                                <% dropdownData.subjects.forEach(s => { %>
                                    <option value="<%= s %>"><%= s %></option>
                                <% }) %>
                            </select>
                        </div>
                        <div class="grid grid-cols-2 gap-4">
                            <div>
                                <label class="block text-xs font-bold text-gray-400 uppercase tracking-widest mb-2">Year</label>
                                <select name="assignedYears" id="yearSelect" onchange="handleYearChange()" class="w-full rounded-xl border-gray-200 dark:border-gray-700 bg-gray-50 dark:bg-gray-900 text-sm p-3 focus:ring-2 focus:ring-primary-500" disabled>
                                    <option value="">Select Year</option>
                                </select>
                            </div>
                            <div>
                                <label class="block text-xs font-bold text-gray-400 uppercase tracking-widest mb-2">Section</label>
                                <select name="assignedSections" id="sectionSelect" class="w-full rounded-xl border-gray-200 dark:border-gray-700 bg-gray-50 dark:bg-gray-900 text-sm p-3 focus:ring-2 focus:ring-primary-500" disabled>
                                    <option value="">Select Section</option>
                                </select>
                            </div>
                        </div>
                        <div class="pt-6">
                            <button type="submit" id="btnSubmitAssign" class="w-full py-3 bg-indigo-600 hover:bg-indigo-700 text-white rounded-xl font-bold shadow-lg transition-all active:scale-95 disabled:opacity-50 disabled:cursor-not-allowed">Assign Academic Load</button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>

    <script>
        const subjectMapping = <%- JSON.stringify(dropdownData.subjectMapping) %>;

        function openUnifiedModal(id, name, role, subject) {
            document.getElementById('modalTargetName').textContent = `Configuring: ${name}`;
            document.getElementById('promoteUserId').value = id;
            document.getElementById('assignUserId').value = id;
            document.getElementById('roleSelect').value = role;
            document.getElementById('promoSubject').value = subject || '';
            
            togglePromoSubject();
            document.getElementById('unifiedModal').classList.remove('hidden');
        }

        function closeUnifiedModal() {
            document.getElementById('unifiedModal').classList.add('hidden');
        }

        function showTab(tab) {
            const btnPromote = document.getElementById('tab-promote');
            const btnAssign = document.getElementById('tab-assign');
            const contentPromote = document.getElementById('content-promote');
            const contentAssign = document.getElementById('content-assign');

            if (tab === 'promote') {
                btnPromote.classList.add('border-primary-500', 'text-primary-600', 'font-bold');
                btnPromote.classList.remove('text-gray-500', 'border-transparent');
                
                btnAssign.classList.remove('border-primary-500', 'text-primary-600', 'font-bold');
                btnAssign.classList.add('text-gray-500', 'border-transparent');

                contentPromote.classList.remove('hidden');
                contentAssign.classList.add('hidden');
            } else {
                btnAssign.classList.add('border-primary-500', 'text-primary-600', 'font-bold');
                btnAssign.classList.remove('text-gray-500', 'border-transparent');
                
                btnPromote.classList.remove('border-primary-500', 'text-primary-600', 'font-bold');
                btnPromote.classList.add('text-gray-500', 'border-transparent');

                contentAssign.classList.remove('hidden');
                contentPromote.classList.add('hidden');
            }
        }

        function togglePromoSubject() {
            const role = document.getElementById('roleSelect').value;
            const container = document.getElementById('promoSubjectContainer');
            if (role === 'hos') {
                container.classList.remove('hidden');
                document.getElementById('promoSubject').required = true;
            } else {
                container.classList.add('hidden');
                document.getElementById('promoSubject').required = false;
            }
        }

        function handleSubjectChange() {
            const subject = document.getElementById('mainSubjectSelect').value;
            const yearSelect = document.getElementById('yearSelect');
            const sectionSelect = document.getElementById('sectionSelect');
            const btn = document.getElementById('btnSubmitAssign');

            yearSelect.innerHTML = '<option value="">Select Year</option>';
            sectionSelect.innerHTML = '<option value="">Select Section</option>';
            yearSelect.disabled = true;
            sectionSelect.disabled = true;
            btn.disabled = true;

            if (subject && subjectMapping[subject]) {
                const uniqueYears = [...new Set(subjectMapping[subject].map(m => m.year))];
                uniqueYears.sort().forEach(y => {
                    const opt = document.createElement('option');
                    opt.value = y;
                    opt.textContent = y;
                    yearSelect.appendChild(opt);
                });
                yearSelect.disabled = false;
            }
        }

        function handleYearChange() {
            const subject = document.getElementById('mainSubjectSelect').value;
            const year = document.getElementById('yearSelect').value;
            const sectionSelect = document.getElementById('sectionSelect');
            const btn = document.getElementById('btnSubmitAssign');

            sectionSelect.innerHTML = '<option value="">Select Section</option>';
            sectionSelect.disabled = true;
            btn.disabled = true;

            if (subject && year && subjectMapping[subject]) {
                const availableSections = subjectMapping[subject]
                    .filter(m => m.year === year)
                    .map(m => m.section);
                
                availableSections.sort().forEach(s => {
                    const opt = document.createElement('option');
                    opt.value = s;
                    opt.textContent = s;
                    sectionSelect.appendChild(opt);
                });
                sectionSelect.disabled = false;
                btn.disabled = false;
            }
        }

        // Global Search Logic
        const globalSearchModal = document.getElementById('global-search-modal');
        const globalTeacherSearchInput = document.getElementById('globalTeacherSearchInput');
        const globalSearchResults = document.getElementById('globalSearchResults');

        if (document.getElementById('btn-global-search')) {
            document.getElementById('btn-global-search').addEventListener('click', () => {
                globalSearchModal.classList.remove('hidden');
                globalTeacherSearchInput.focus();
            });
        }

        function closeGlobalSearch() {
            globalSearchModal.classList.add('hidden');
        }

        let searchTimeout;
        if (globalTeacherSearchInput) {
            globalTeacherSearchInput.addEventListener('input', (e) => {
                clearTimeout(searchTimeout);
                const q = e.target.value;
                if (q.length < 2) {
                    globalSearchResults.innerHTML = '<p class="text-center text-gray-500 py-8 italic">Type at least 2 characters...</p>';
                    return;
                }

                searchTimeout = setTimeout(() => {
                    fetch(`/college/hod/api/search-teachers?q=${encodeURIComponent(q)}`)
                        .then(res => res.json())
                        .then(data => {
                            if (data.length === 0) {
                                globalSearchResults.innerHTML = '<p class="text-center text-gray-500 py-8 italic">No teachers found.</p>';
                            } else {
                                globalSearchResults.innerHTML = data.map(t => `
                                    <div class="flex items-center justify-between p-3 rounded-xl hover:bg-gray-50 dark:hover:bg-gray-700/50 transition-colors border border-transparent hover:border-gray-100 dark:hover:border-gray-600">
                                        <div class="flex items-center gap-3">
                                            <div class="w-10 h-10 rounded-full bg-indigo-100 dark:bg-indigo-900/30 flex items-center justify-center text-indigo-600 dark:text-indigo-400 font-bold text-xs">
                                                ${t.fullName.split(' ').map(n => n[0]).join('')}
                                            </div>
                                            <div>
                                                <h4 class="text-sm font-bold text-gray-800 dark:text-white">${t.fullName}</h4>
                                                <p class="text-xs text-gray-500">${t.email} • ${t.department}</p>
                                            </div>
                                        </div>
                                        <div class="flex gap-2">
                                            <button onclick="openAssignSubjectModal(${t.id}, ${JSON.stringify(t.fullName)})" class="px-3 py-1.5 text-xs font-bold bg-indigo-500/10 text-indigo-600 dark:text-indigo-400 hover:bg-indigo-500/20 rounded-lg transition-colors">Assign Subject</button>
                                        </div>
                                    </div>
                                `).join('');
                            }
                        });
                }, 300);
            });
        }

        function openAssignSubjectModal(id, name) {
            openUnifiedModal(id, name, 'faculty', '');
            showTab('assign');
        }

        function editFaculty(id, name, email, joiningDate) {
            document.getElementById('editFacultyId').value = id;
            document.getElementById('editFacultyName').value = name;
            document.getElementById('editFacultyEmail').value = email;
            document.getElementById('editFacultyJoiningDate').value = joiningDate;
            document.getElementById('editFacultyModal').classList.remove('hidden');
        }

        // Form Submissions
        document.addEventListener('DOMContentLoaded', () => {
            const promoteForm = document.getElementById('promoteForm');
            if(promoteForm) {
                promoteForm.addEventListener('submit', async (e) => {
                    e.preventDefault();
                    const id = document.getElementById('promoteUserId').value;
                    const role = document.getElementById('roleSelect').value;
                    const subject = document.getElementById('promoSubject').value;

                    try {
                        const res = await fetch('/college/hod/api/assign-role', {
                            method: 'POST',
                            headers: { 'Content-Type': 'application/json' },
                            body: JSON.stringify({ id, role, subject })
                        });
                        const data = await res.json();
                        if (data.success) {
                            location.reload();
                        } else {
                            alert(data.message);
                        }
                    } catch (err) {
                        alert('Connection error');
                    }
                });
            }

            const assignForm = document.getElementById('assignForm');
            if(assignForm) {
                assignForm.addEventListener('submit', async (e) => {
                    e.preventDefault();
                    const formData = new FormData(e.target);
                    const body = Object.fromEntries(formData.entries());

                    try {
                        const res = await fetch('/college/hod/api/assign-sections', {
                            method: 'POST',
                            headers: { 'Content-Type': 'application/json' },
                            body: JSON.stringify(body)
                        });
                        const data = await res.json();
                        if (data.success) {
                            location.reload();
                        } else {
                            alert(data.message);
                        }
                    } catch (err) {
                        alert('Connection error');
                    }
                });
            }
        });

        function confirmVerify(id) {
            if (confirm('Verify this faculty member?')) {
                verifyFaculty(id);
            }
        }

        async function verifyFaculty(id) {
            try {
                const res = await fetch('/college/hod/api/verify-faculty', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ id })
                });
                const data = await res.json();
                if (data.success) {
                    location.reload();
                } else {
                    alert('Error verifying faculty: ' + data.message);
                }
            } catch (err) {
                alert('Error connecting to server');
            }
        }

        async function deleteFaculty(id) {
            if (!confirm('Are you sure you want to remove this faculty member? This action cannot be undone.')) return;
            try {
                const res = await fetch('/college/hod/api/delete-faculty', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ id })
                });
                const data = await res.json();
                if (data.success) {
                    location.reload();
                } else {
                    alert('Error deleting faculty: ' + data.message);
                }
            } catch (err) {
                alert('Connection error');
            }
        }

        // Edit Faculty Form Submission
        const editForm = document.getElementById('editFacultyForm');
        if (editForm) {
            editForm.addEventListener('submit', async (e) => {
                e.preventDefault();
                const id = document.getElementById('editFacultyId').value;
                const fullName = document.getElementById('editFacultyName').value;
                const email = document.getElementById('editFacultyEmail').value;
                const joiningDate = document.getElementById('editFacultyJoiningDate').value;

                try {
                    const res = await fetch('/college/hod/api/update-faculty', {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify({ id, fullName, email, joiningDate })
                    });
                    const data = await res.json();
                    if (data.success) {
                        location.reload();
                    } else {
                        alert('Error updating faculty: ' + data.message);
                    }
                } catch (err) {
                    alert('Connection error');
                }
            });
        }

        // UI Helpers
        if(document.getElementById('closeEditFacultyModal')) {
            document.getElementById('closeEditFacultyModal').onclick = () => {
                document.getElementById('editFacultyModal').classList.add('hidden');
            };
        }
        if(document.getElementById('cancelEditFaculty')) {
            document.getElementById('cancelEditFaculty').onclick = () => {
                document.getElementById('editFacultyModal').classList.add('hidden');
            };
        }
    </script>
    <!-- PROFILE OVERLAY -->
    <div id="profileOverlay"
        class="fixed inset-0 z-[80] flex items-center justify-center bg-black/50 backdrop-blur-sm hidden">
        <div
            class="w-[380px] bg-white dark:bg-gray-800 rounded-3xl shadow-2xl overflow-hidden animate-[fadeIn_0.2s_ease-out]">
            <div class="bg-gradient-to-br from-[#1E4A7A] to-[#153255] relative pt-12 pb-20 px-6 text-center">
                <button id="closeProfileOverlay"
                    class="absolute top-4 right-4 w-8 h-8 rounded-full bg-white/10 hover:bg-white/20 text-white/90 transition-all flex items-center justify-center backdrop-blur-sm">
                    <i class="fas fa-times text-sm"></i>
                </button>

                <div class="absolute left-1/2 bottom-[-48px] -translate-x-1/2">
                    <div
                        class="relative w-24 h-24 rounded-full p-1.5 bg-white dark:bg-gray-800 ring-4 ring-[#1E4A7A]/10 dark:ring-[#1E4A7A]/30">
                        <div
                            class="w-full h-full rounded-full bg-gradient-to-br from-blue-500 to-indigo-600 flex items-center justify-center text-white text-3xl font-bold shadow-inner">
                            <%= user.fullName.split(' ').map(n => n[0]).join('').toUpperCase().slice(0,2) %>
                        </div>
                        <div
                            class="absolute bottom-0 right-0 w-6 h-6 bg-green-500 border-4 border-white dark:border-gray-800 rounded-full">
                        </div>
                    </div>
                </div>
            </div>

            <div class="pt-16 pb-8 px-6">
                <div class="text-center mb-6">
                    <h2 class="text-2xl font-bold text-gray-900 dark:text-white mb-1"><%= user.fullName %></h2>
                    <p class="text-sm font-medium text-gray-500 dark:text-gray-400 mb-3"><%= user.post || 'Head of Department' %></p>

                    <div class="flex items-center justify-center gap-2 flex-wrap">
                        <span
                            class="px-3 py-1 rounded-full text-xs font-semibold bg-blue-50 text-blue-700 dark:bg-blue-900/30 dark:text-blue-300 border border-blue-100 dark:border-blue-800">
                            <%= user.department %> Dept
                        </span>
                        <span
                            class="px-3 py-1 rounded-full text-xs font-semibold bg-purple-50 text-purple-700 dark:bg-purple-900/30 dark:text-purple-300 border border-purple-100 dark:border-purple-800">
                            HOD
                        </span>
                    </div>
                </div>

                <div class="grid grid-cols-2 gap-4 mb-6">
                    <div
                        class="p-3 rounded-2xl bg-gray-50 dark:bg-gray-700/30 border border-gray-100 dark:border-gray-700 text-center">
                        <p class="text-xs text-gray-500 uppercase font-semibold">Faculty ID</p>
                        <p class="text-sm font-bold text-gray-800 dark:text-gray-200">FAC-<%= user.id %></p>
                    </div>
                    <div
                        class="p-3 rounded-2xl bg-gray-50 dark:bg-gray-700/30 border border-gray-100 dark:border-gray-700 text-center">
                        <p class="text-xs text-gray-500 uppercase font-semibold">Joined</p>
                        <p class="text-sm font-bold text-gray-800 dark:text-gray-200"><%= user.joiningDate || 'Aug 2023' %></p>
                    </div>
                </div>

                <div class="space-y-3">
                    <button id="logoutBtn"
                        class="w-full flex items-center justify-between p-3 rounded-xl hover:bg-red-50 dark:hover:bg-red-900/20 group transition-all duration-200 border border-transparent hover:border-red-100 dark:hover:border-red-800">
                        <div class="flex items-center gap-3">
                            <div
                                class="w-8 h-8 rounded-full bg-red-50 dark:bg-red-900/20 text-red-600 dark:text-red-400 flex items-center justify-center">
                                <i class="fas fa-sign-out-alt text-sm"></i>
                            </div>
                            <span
                                class="text-sm font-medium text-gray-700 dark:text-gray-200 group-hover:text-red-600 dark:group-hover:text-red-400">Logout</span>
                        </div>
                        <i
                            class="fas fa-chevron-right text-xs text-gray-400 group-hover:text-red-500 dark:group-hover:text-red-400"></i>
                    </button>
                </div>
            </div>
        </div>
    </div>

    <script src="/js/Hod/index1_logic.js"></script>
</body>

</html>