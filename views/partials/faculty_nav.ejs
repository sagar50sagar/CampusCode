<style>
    #mainSidebar .nav-item {
        display: flex;
        align-items: center;
        gap: 0.75rem;
        padding: 0.75rem 1rem;
        border-radius: 0.75rem;
        font-size: 1.125rem;
        font-weight: 500;
        color: #4b5563;
        transition: all 0.2s ease;
        position: relative;
    }
    .dark #mainSidebar .nav-item { color: #d1d5db; }
    #mainSidebar .nav-item:hover { background: #f3f4f6; color: #1e4a7a; }
    .dark #mainSidebar .nav-item:hover { background: #374151; color: #93c5fd; }
    #mainSidebar .nav-item.active {
        background: #e7f0fa;
        color: #1e4a7a;
    }
    .dark #mainSidebar .nav-item.active {
        background: rgba(30, 74, 122, 0.25);
        color: #93c5fd;
    }
    #mainSidebar .nav-item.active::before {
        content: "";
        position: absolute;
        left: 0;
        top: 50%;
        transform: translateY(-50%);
        width: 4px;
        height: 60%;
        background: #1e4a7a;
        border-radius: 0 4px 4px 0;
    }
    .dark #mainSidebar .nav-item.active::before { background: #93c5fd; }
    #mainSidebar .nav-item i { width: 1.25rem; text-align: center; flex-shrink: 0; }
    #mainSidebar.sidebar.collapsed .nav-item { justify-content: center; padding-left: 0; padding-right: 0; }
    #mainSidebar.sidebar.collapsed .nav-item span { display: none; }
</style>

<aside id="mainSidebar" class="sidebar w-64 bg-white dark:bg-gray-800 shadow-sm border-r border-gray-200 dark:border-gray-700 flex flex-col h-screen flex-shrink-0 transition-colors duration-200 z-50">
