<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Settings - HOD Dashboard</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&display=swap" rel="stylesheet" />
    <script src="https://cdn.tailwindcss.com"></script>
    <script>
        tailwind.config = {
            darkMode: 'class',
            theme: {
                extend: {
                    fontFamily: { sans: ["Poppins", "sans-serif"] },
                    colors: {
                        primary: { 50: "#E7F0FA", 100: "#D0E1F5", 200: "#7BA4D0", 300: "#4D84C0", 400: "#2E5E99", 500: "#1E4A7A", 600: "#0D2440" },
                        dark: { bg: "#111827", card: "#1F2937", text: "#F9FAFB", border: "#374151" }
                    },
                },
            },
        };
    </script>
    <style>
        ::-webkit-scrollbar { width: 6px; height: 6px; }
        ::-webkit-scrollbar-track { background: transparent; }
        .dark ::-webkit-scrollbar-track { background: #111827; }
        ::-webkit-scrollbar-thumb { background: #7ba4d0; border-radius: 3px; }
        ::-webkit-scrollbar-thumb:hover { background: #2e5e99; }
        .sidebar.collapsed { width: 5rem !important; }
        .sidebar.collapsed .sidebar-hide { display: none !important; }
        .sidebar.collapsed nav a, .sidebar.collapsed div.p-4 a { justify-content: center !important; padding-left: 0 !important; padding-right: 0 !important; }
        .sidebar.collapsed nav a span, .sidebar.collapsed div.p-4 a span { display: none !important; }
    </style>
</head>
<body class="bg-gray-50 dark:bg-gray-900 min-h-screen font-sans transition-colors duration-200">
<div class="flex h-screen overflow-hidden">

    <!-- SIDEBAR -->
    <aside id="mainSidebar" class="sidebar w-64 bg-white dark:bg-gray-800 shadow-sm border-r border-gray-200 dark:border-gray-700 flex flex-col h-screen flex-shrink-0 transition-all duration-300 z-50">
        <div class="p-6 flex-shrink-0 flex items-center justify-between h-[88px]">
            <h1 class="text-2xl font-bold text-gray-800 dark:text-white flex items-center gap-2 overflow-hidden whitespace-nowrap">
                <i class="fas fa-code text-primary-500 text-2xl flex-shrink-0"></i>
                <span id="sidebarLogoText" class="transition-all duration-300 opacity-100 sidebar-hide">CampusCode</span>
            </h1>
            <button id="sidebarToggleBtn" class="p-1.5 rounded-lg text-gray-400 hover:bg-gray-100 dark:hover:bg-gray-700 hover:text-primary-500 transition-colors focus:outline-none">
                <i class="fas fa-chevron-left transition-transform duration-300"></i>
            </button>
        </div>

        <nav class="flex-1 space-y-1 overflow-y-auto mt-2 font-sans">
            <a href="/college/hod/dashboard" class="group flex items-center gap-3 px-6 py-3.5 text-sm font-medium transition-all <%= currentPage === 'dashboard' ? 'bg-primary-50 dark:bg-primary-900/20 text-primary-600 dark:text-primary-400 border-r-4 border-primary-600 dark:border-primary-400' : 'text-gray-600 dark:text-gray-300 hover:bg-gray-50 dark:hover:bg-gray-700 border-r-4 border-transparent' %>">
                <i class="fas fa-home w-5 text-center text-lg"></i>
                <span class="whitespace-nowrap sidebar-hide">Dashboard</span>
            </a>
            <a href="/college/hod/problem" class="group flex items-center gap-3 px-6 py-3.5 text-sm font-medium transition-all <%= currentPage === 'problem' ? 'bg-primary-50 dark:bg-primary-900/20 text-primary-600 dark:text-primary-400 border-r-4 border-primary-600 dark:border-primary-400' : 'text-gray-600 dark:text-gray-300 hover:bg-gray-50 dark:hover:bg-gray-700 border-r-4 border-transparent' %>">
                <i class="fas fa-tasks w-5 text-center text-lg"></i>
                <span class="whitespace-nowrap sidebar-hide">Problems</span>
            </a>
            <a href="/college/hod/contest" class="group flex items-center gap-3 px-6 py-3.5 text-sm font-medium transition-all <%= currentPage === 'contest' ? 'bg-primary-50 dark:bg-primary-900/20 text-primary-600 dark:text-primary-400 border-r-4 border-primary-600 dark:border-primary-400' : 'text-gray-600 dark:text-gray-300 hover:bg-gray-50 dark:hover:bg-gray-700 border-r-4 border-transparent' %>">
                <i class="fas fa-trophy w-5 text-center text-lg"></i>
                <span class="whitespace-nowrap sidebar-hide">Contests</span>
            </a>
            <a href="/college/hod/faculty" class="group flex items-center gap-3 px-6 py-3.5 text-sm font-medium transition-all <%= currentPage === 'faculty' ? 'bg-primary-50 dark:bg-primary-900/20 text-primary-600 dark:text-primary-400 border-r-4 border-primary-600 dark:border-primary-400' : 'text-gray-600 dark:text-gray-300 hover:bg-gray-50 dark:hover:bg-gray-700 border-r-4 border-transparent' %>">
                <i class="fas fa-users w-5 text-center text-lg"></i>
                <span class="whitespace-nowrap sidebar-hide">Faculty</span>
            </a>
            <a href="/college/hod/student" class="group flex items-center gap-3 px-6 py-3.5 text-sm font-medium transition-all <%= currentPage === 'student' ? 'bg-primary-50 dark:bg-primary-900/20 text-primary-600 dark:text-primary-400 border-r-4 border-primary-600 dark:border-primary-400' : 'text-gray-600 dark:text-gray-300 hover:bg-gray-50 dark:hover:bg-gray-700 border-r-4 border-transparent' %>">
                <i class="fas fa-user-graduate w-5 text-center text-lg"></i>
                <span class="whitespace-nowrap sidebar-hide">Students</span>
            </a>
            <a href="/college/hod/community" class="group flex items-center gap-3 px-6 py-3.5 text-sm font-medium transition-all <%= currentPage === 'community' ? 'bg-primary-50 dark:bg-primary-900/20 text-primary-600 dark:text-primary-400 border-r-4 border-primary-600 dark:border-primary-400' : 'text-gray-600 dark:text-gray-300 hover:bg-gray-50 dark:hover:bg-gray-700 border-r-4 border-transparent' %>">
                <i class="fas fa-comments w-5 text-center text-lg"></i>
                <span class="whitespace-nowrap sidebar-hide">Community</span>
            </a>
            <a href="/college/hod/report" class="group flex items-center gap-3 px-6 py-3.5 text-sm font-medium transition-all <%= currentPage === 'report' ? 'bg-primary-50 dark:bg-primary-900/20 text-primary-600 dark:text-primary-400 border-r-4 border-primary-600 dark:border-primary-400' : 'text-gray-600 dark:text-gray-300 hover:bg-gray-50 dark:hover:bg-gray-700 border-r-4 border-transparent' %>">
                <i class="fas fa-chart-pie w-5 text-center text-lg"></i>
                <span class="whitespace-nowrap sidebar-hide">Reports</span>
            </a>
        </nav>

        <div class="p-4 space-y-1 border-t border-gray-200 dark:border-gray-700 bg-white dark:bg-gray-800 flex-shrink-0">
            <a href="/college/hod/help" class="group flex items-center gap-3 px-6 py-3.5 text-sm font-medium transition-all rounded-lg <%= currentPage === 'help' ? 'bg-primary-50 dark:bg-primary-900/20 text-primary-600 dark:text-primary-400' : 'text-gray-600 dark:text-gray-300 hover:bg-gray-50 dark:hover:bg-gray-700' %>">
                <i class="far fa-question-circle w-5 text-center text-lg group-hover:scale-110 transition-transform"></i>
                <span class="whitespace-nowrap sidebar-hide">Help &amp; Support</span>
            </a>
            <a href="/college/hod/settings" class="group flex items-center gap-3 px-6 py-3.5 text-sm font-medium transition-all rounded-lg <%= currentPage === 'settings' ? 'bg-primary-50 dark:bg-primary-900/20 text-primary-600 dark:text-primary-400' : 'text-gray-600 dark:text-gray-300 hover:bg-gray-50 dark:hover:bg-gray-700' %>">
                <i class="fas fa-cog w-5 text-center text-lg group-hover:rotate-90 transition-transform duration-500"></i>
                <span class="whitespace-nowrap sidebar-hide">Settings</span>
            </a>
        </div>
    </aside>

    <!-- MAIN CONTENT -->
    <div class="flex-1 overflow-y-auto">
        <header class="bg-white dark:bg-gray-800 shadow-sm sticky top-0 z-40 transition-colors duration-200">
            <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-3 flex justify-between items-center">
                <h2 class="text-xl font-bold text-gray-800 dark:text-white ml-4">Settings</h2>
                <div class="flex items-center gap-3">
                    <button id="themeToggleBtn" class="p-2 rounded-full text-gray-500 hover:text-gray-700 dark:text-gray-400 dark:hover:text-gray-200 focus:outline-none transition-transform active:scale-95">
                        <i class="fas fa-moon text-xl"></i>
                    </button>
                    <button id="headerProfileBtn" class="ml-2 flex items-center gap-3 p-1 pr-3 rounded-full hover:bg-gray-100 dark:hover:bg-gray-700 transition-colors">
                        <div class="h-9 w-9 rounded-full bg-primary-500 flex items-center justify-center text-white font-bold text-sm">
                            <%= user.fullName.split(' ').map(n => n[0]).join('').toUpperCase().slice(0,2) %>
                        </div>
                        <span class="text-sm font-medium text-gray-700 dark:text-gray-200 hidden sm:block"><%= user.fullName %></span>
                    </button>
                </div>
            </div>
        </header>

        <main class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-6 space-y-6">

            <% if (typeof success !== 'undefined' && success) { %>
            <div class="bg-green-50 dark:bg-green-900/30 border-l-4 border-green-500 p-4 rounded-r-lg">
                <div class="flex">
                    <div class="flex-shrink-0"><i class="fas fa-check-circle text-green-500"></i></div>
                    <div class="ml-3">
                        <p class="text-sm text-green-700 dark:text-green-300 font-medium">Settings updated successfully!</p>
                    </div>
                </div>
            </div>
            <% } %>

            <!-- Profile Form -->
            <form action="/college/hod/settings/update" method="POST" class="space-y-6">

                <!-- Editable Section -->
                <div class="bg-white dark:bg-gray-800 rounded-xl shadow-sm border border-gray-200 dark:border-gray-700 p-6">
                    <h3 class="text-base font-semibold text-gray-800 dark:text-white mb-6">Profile Information (Editable)</h3>

                    <div class="flex items-center gap-5 mb-6">
                        <div class="w-16 h-16 rounded-full bg-gradient-to-br from-blue-500 to-indigo-600 flex items-center justify-center text-white text-2xl font-bold flex-shrink-0">
                            <%= user.fullName.split(' ').map(n => n[0]).join('').toUpperCase().slice(0,2) %>
                        </div>
                        <div>
                            <h4 class="text-lg font-bold text-gray-900 dark:text-white"><%= user.fullName %></h4>
                            <p class="text-sm text-gray-500 dark:text-gray-400"><%= user.post || 'Head of Department' %></p>
                            <p class="text-xs text-gray-400 dark:text-gray-500 mt-0.5"><%= user.collegeName %></p>
                        </div>
                    </div>

                    <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                        <div>
                            <label class="block text-xs font-medium text-gray-500 dark:text-gray-400 uppercase mb-1">Full Name</label>
                            <input type="text" name="fullName" value="<%= user.fullName %>"
                                class="w-full rounded-lg border border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-700 px-4 py-2.5 text-sm text-gray-900 dark:text-white focus:ring-2 focus:ring-primary-500 focus:border-transparent outline-none transition-all">
                        </div>
                        <div>
                            <label class="block text-xs font-medium text-gray-500 dark:text-gray-400 uppercase mb-1">Email</label>
                            <input type="email" name="email" value="<%= user.email || '' %>"
                                class="w-full rounded-lg border border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-700 px-4 py-2.5 text-sm text-gray-900 dark:text-white focus:ring-2 focus:ring-primary-500 focus:border-transparent outline-none transition-all">
                        </div>
                        <div>
                            <label class="block text-xs font-medium text-gray-500 dark:text-gray-400 uppercase mb-1">Gender</label>
                            <select name="gender" class="w-full rounded-lg border border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-700 px-4 py-2.5 text-sm text-gray-900 dark:text-white focus:ring-2 focus:ring-primary-500 focus:border-transparent outline-none transition-all">
                                <option value="" <%= !user.gender ? 'selected' : '' %>>Select Gender</option>
                                <option value="Male" <%= user.gender === 'Male' ? 'selected' : '' %>>Male</option>
                                <option value="Female" <%= user.gender === 'Female' ? 'selected' : '' %>>Female</option>
                                <option value="Other" <%= user.gender === 'Other' ? 'selected' : '' %>>Other</option>
                            </select>
                        </div>
                        <div>
                            <label class="block text-xs font-medium text-gray-500 dark:text-gray-400 uppercase mb-1">Mobile Number</label>
                            <input type="text" name="mobile" value="<%= user.mobile || '' %>"
                                class="w-full rounded-lg border border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-700 px-4 py-2.5 text-sm text-gray-900 dark:text-white focus:ring-2 focus:ring-primary-500 focus:border-transparent outline-none transition-all">
                        </div>
                    </div>
                    <div class="flex justify-end mt-6">
                        <button type="submit" class="bg-primary-500 hover:bg-primary-600 text-white px-6 py-2.5 rounded-lg text-sm font-medium transition-colors shadow-sm">
                            Save Changes
                        </button>
                    </div>
                </div>
            </form>

            <!-- System Information (Read-Only) -->
            <div class="bg-white dark:bg-gray-800 rounded-xl shadow-sm border border-gray-200 dark:border-gray-700 p-6">
                <h3 class="text-base font-semibold text-gray-800 dark:text-white mb-6 flex items-center gap-2">
                    <i class="fas fa-shield-alt text-gray-400"></i> System Information (Read-Only)
                </h3>
                <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
                    <div>
                        <label class="block text-xs font-medium text-gray-500 dark:text-gray-400 uppercase mb-1">Role</label>
                        <div class="w-full rounded-lg border border-gray-200 dark:border-gray-700 bg-gray-50 dark:bg-gray-900/50 px-4 py-2.5 text-sm text-gray-600 dark:text-gray-400 cursor-not-allowed flex items-center">
                            <i class="fas fa-lock text-xs mr-2 opacity-50"></i><%= user.role ? user.role.toUpperCase() : 'HOD' %>
                        </div>
                    </div>
                    <div>
                        <label class="block text-xs font-medium text-gray-500 dark:text-gray-400 uppercase mb-1">Department</label>
                        <div class="w-full rounded-lg border border-gray-200 dark:border-gray-700 bg-gray-50 dark:bg-gray-900/50 px-4 py-2.5 text-sm text-gray-600 dark:text-gray-400 cursor-not-allowed flex items-center">
                            <i class="fas fa-lock text-xs mr-2 opacity-50"></i><%= user.department || 'Not Assigned' %>
                        </div>
                    </div>
                    <div>
                        <label class="block text-xs font-medium text-gray-500 dark:text-gray-400 uppercase mb-1">College</label>
                        <div class="w-full rounded-lg border border-gray-200 dark:border-gray-700 bg-gray-50 dark:bg-gray-900/50 px-4 py-2.5 text-sm text-gray-600 dark:text-gray-400 cursor-not-allowed flex items-center">
                            <i class="fas fa-lock text-xs mr-2 opacity-50"></i><%= user.collegeName || 'Not Assigned' %>
                        </div>
                    </div>
                </div>
                <div class="mt-4">
                    <label class="block text-xs font-medium text-gray-500 dark:text-gray-400 uppercase mb-1">Course</label>
                    <div class="w-full rounded-lg border border-gray-200 dark:border-gray-700 bg-gray-50 dark:bg-gray-900/50 px-4 py-2.5 text-sm text-gray-600 dark:text-gray-400 cursor-not-allowed flex items-center">
                        <i class="fas fa-lock text-xs mr-2 opacity-50"></i><%= user.course || 'Not Specified' %>
                    </div>
                </div>

                <h4 class="text-sm font-medium text-gray-700 dark:text-gray-300 mt-6 mb-3">Academic Assignments</h4>
                <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
                    <div>
                        <p class="text-xs font-medium text-gray-500 dark:text-gray-400 uppercase mb-2">Assigned Years</p>
                        <div class="flex flex-wrap gap-2">
                            <%
                            let parsedYears = [];
                            try { parsedYears = user.assignedYears ? user.assignedYears.split(',') : []; } catch(e) {}
                            if (parsedYears.length === 0) { %>
                                <span class="bg-gray-100 text-gray-600 dark:bg-gray-800 dark:text-gray-400 px-3 py-1 rounded-full text-xs font-medium border border-gray-200 dark:border-gray-700">None</span>
                            <% } else { parsedYears.forEach(year => { if(year.trim()){ %>
                                <span class="bg-blue-50 text-blue-700 dark:bg-blue-900/30 dark:text-blue-300 px-3 py-1 rounded-full text-xs font-medium border border-blue-100 dark:border-blue-800 flex items-center gap-1.5">
                                    <i class="fas fa-lock text-[10px] opacity-70"></i> <%= year.trim() %>
                                </span>
                            <% }}); } %>
                        </div>
                    </div>
                    <div>
                        <p class="text-xs font-medium text-gray-500 dark:text-gray-400 uppercase mb-2">Assigned Sections</p>
                        <div class="flex flex-wrap gap-2">
                            <%
                            let parsedSections = [];
                            try { parsedSections = user.assignedSections ? user.assignedSections.split(',') : []; } catch(e) {}
                            if (parsedSections.length === 0) { %>
                                <span class="bg-gray-100 text-gray-600 dark:bg-gray-800 dark:text-gray-400 px-3 py-1 rounded-full text-xs font-medium border border-gray-200 dark:border-gray-700">None</span>
                            <% } else { parsedSections.forEach(section => { if(section.trim()){ %>
                                <span class="bg-purple-50 text-purple-700 dark:bg-purple-900/30 dark:text-purple-300 px-3 py-1 rounded-full text-xs font-medium border border-purple-100 dark:border-purple-800 flex items-center gap-1.5">
                                    <i class="fas fa-lock text-[10px] opacity-70"></i> <%= section.trim() %>
                                </span>
                            <% }}); } %>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Appearance -->
            <div class="bg-white dark:bg-gray-800 rounded-xl shadow-sm border border-gray-200 dark:border-gray-700 p-6">
                <h3 class="text-base font-semibold text-gray-800 dark:text-white mb-4">Appearance</h3>
                <div class="flex gap-3">
                    <button type="button" onclick="applyTheme('light')" class="flex-1 p-3 rounded-xl border-2 border-gray-200 dark:border-gray-700 hover:border-primary-500 transition-all flex flex-col items-center gap-2 text-sm font-medium text-gray-600 dark:text-gray-400">
                        <i class="fas fa-sun text-orange-400 text-xl"></i> Light
                    </button>
                    <button type="button" onclick="applyTheme('dark')" class="flex-1 p-3 rounded-xl border-2 border-gray-200 dark:border-gray-700 hover:border-primary-500 transition-all flex flex-col items-center gap-2 text-sm font-medium text-gray-600 dark:text-gray-400">
                        <i class="fas fa-moon text-indigo-400 text-xl"></i> Dark
                    </button>
                    <button type="button" onclick="applyTheme('system')" class="flex-1 p-3 rounded-xl border-2 border-gray-200 dark:border-gray-700 hover:border-primary-500 transition-all flex flex-col items-center gap-2 text-sm font-medium text-gray-600 dark:text-gray-400">
                        <i class="fas fa-desktop text-gray-400 text-xl"></i> System
                    </button>
                </div>
            </div>

            <!-- Danger Zone -->
            <div class="bg-white dark:bg-gray-800 rounded-xl shadow-sm border border-red-100 dark:border-red-900/30 p-6">
                <h3 class="text-base font-semibold text-gray-800 dark:text-white mb-2">Danger Zone</h3>
                <p class="text-sm text-gray-500 dark:text-gray-400 mb-4">End your session securely.</p>
                <a href="/auth/logout" class="inline-flex items-center gap-2 px-5 py-2.5 bg-red-600 hover:bg-red-700 text-white rounded-lg text-sm font-medium transition-colors">
                    <i class="fas fa-sign-out-alt"></i> Sign Out
                </a>
            </div>
        </main>
    </div>
</div>

<!-- Profile Overlay -->
    <div id="profileOverlay" class="fixed inset-0 z-[80] flex items-center justify-center bg-black/50 backdrop-blur-sm hidden">
        <div class="w-[380px] bg-white dark:bg-gray-800 rounded-3xl shadow-2xl overflow-hidden animate-[fadeIn_0.2s_ease-out]">
            <div class="bg-gradient-to-br from-[#1E4A7A] to-[#153255] relative pt-12 pb-20 px-6 text-center">
                <button id="closeProfileOverlay" class="absolute top-4 right-4 w-8 h-8 rounded-full bg-white/10 hover:bg-white/20 text-white/90 transition-all flex items-center justify-center backdrop-blur-sm">
                    <i class="fas fa-times text-sm"></i>
                </button>

                <div class="absolute left-1/2 bottom-[-48px] -translate-x-1/2">
                    <div class="relative w-24 h-24 rounded-full p-1.5 bg-white dark:bg-gray-800 ring-4 ring-[#1E4A7A]/10 dark:ring-[#1E4A7A]/30">
                        <div class="w-full h-full rounded-full bg-gradient-to-br from-blue-500 to-indigo-600 flex items-center justify-center text-white text-3xl font-bold shadow-inner">
                            <%= user.fullName.split(' ').map(n => n[0]).join('').toUpperCase().slice(0,2) %>
                        </div>
                        <div class="absolute bottom-0 right-0 w-6 h-6 bg-green-500 border-4 border-white dark:border-gray-800 rounded-full"></div>
                    </div>
                </div>
            </div>

            <div class="pt-16 pb-8 px-6">
                <div class="text-center mb-6">
                    <h2 class="text-2xl font-bold text-gray-900 dark:text-white mb-1"><%= user.fullName %></h2>
                    <p class="text-sm font-medium text-gray-500 dark:text-gray-400 mb-3"><%= user.post || 'Faculty Member' %></p>

                    <div class="flex items-center justify-center gap-2 flex-wrap">
                        <span class="px-3 py-1 rounded-full text-xs font-semibold bg-blue-50 text-blue-700 dark:bg-blue-900/30 dark:text-blue-300 border border-blue-100 dark:border-blue-800">
                            <%= user.department || 'General' %> Dept
                        </span>
                        <span class="px-3 py-1 rounded-full text-xs font-semibold bg-purple-50 text-purple-700 dark:bg-purple-900/30 dark:text-purple-300 border border-purple-100 dark:border-purple-800">
                            <%= user.role ? user.role.toUpperCase() : 'FACULTY' %>
                        </span>
                    </div>
                </div>

                <div class="grid grid-cols-2 gap-4 mb-6">
                    <div class="p-3 rounded-2xl bg-gray-50 dark:bg-gray-700/30 border border-gray-100 dark:border-gray-700 text-center">
                        <p class="text-xs text-gray-500 uppercase font-semibold">Faculty ID</p>
                        <p class="text-sm font-bold text-gray-800 dark:text-gray-200">FAC-<%= user.id %></p>
                    </div>
                    <div class="p-3 rounded-2xl bg-gray-50 dark:bg-gray-700/30 border border-gray-100 dark:border-gray-700 text-center">
                        <p class="text-xs text-gray-500 uppercase font-semibold">Joined</p>
                        <p class="text-sm font-bold text-gray-800 dark:text-gray-200"><%= user.joiningDate || 'Unknown' %></p>
                    </div>
                </div>

                <div class="space-y-3">
                    <button id="logoutBtn" class="w-full flex items-center justify-between p-3 rounded-xl hover:bg-red-50 dark:hover:bg-red-900/20 group transition-all duration-200 border border-transparent hover:border-red-100 dark:hover:border-red-800">
                        <div class="flex items-center gap-3">
                            <div class="w-8 h-8 rounded-full bg-red-50 dark:bg-red-900/20 text-red-600 dark:text-red-400 flex items-center justify-center">
                                <i class="fas fa-sign-out-alt text-sm"></i>
                            </div>
                            <span class="text-sm font-medium text-gray-700 dark:text-gray-200 group-hover:text-red-600 dark:group-hover:text-red-400">Logout</span>
                        </div>
                        <i class="fas fa-chevron-right text-xs text-gray-400 group-hover:text-red-500 dark:group-hover:text-red-400"></i>
                    </button>
                </div>
            </div>
        </div>
    </div>

<script>
    document.addEventListener('DOMContentLoaded', function () {

        // Sidebar toggle
        const sidebar = document.getElementById('mainSidebar');
        const toggleBtn = document.getElementById('sidebarToggleBtn');
        const toggleIcon = toggleBtn ? toggleBtn.querySelector('i') : null;
        const sidebarLogoText = document.getElementById('sidebarLogoText');

        if (toggleBtn && sidebar) {
            toggleBtn.addEventListener('click', () => {
                sidebar.classList.toggle('collapsed');
                if (sidebar.classList.contains('collapsed')) {
                    sidebar.classList.replace('w-64', 'w-20');
                    if (toggleIcon) toggleIcon.style.transform = 'rotate(180deg)';
                    if (sidebarLogoText) { sidebarLogoText.style.opacity = '0'; sidebarLogoText.style.width = '0px'; }
                } else {
                    sidebar.classList.replace('w-20', 'w-64');
                    if (toggleIcon) toggleIcon.style.transform = 'rotate(0deg)';
                    if (sidebarLogoText) { sidebarLogoText.style.opacity = '1'; sidebarLogoText.style.width = 'auto'; }
                }
            });
        }

        // Theme
        function applyTheme(themeName) {
            const html = document.documentElement;
            if (themeName === 'dark') { html.classList.add('dark'); localStorage.theme = 'dark'; }
            else if (themeName === 'light') { html.classList.remove('dark'); localStorage.theme = 'light'; }
            else {
                localStorage.removeItem('theme');
                if (window.matchMedia('(prefers-color-scheme: dark)').matches) html.classList.add('dark');
                else html.classList.remove('dark');
            }
            const icon = document.querySelector('#themeToggleBtn i');
            if (icon) {
                icon.className = html.classList.contains('dark') ? 'fas fa-sun text-xl' : 'fas fa-moon text-xl';
            }
        }
        window.applyTheme = applyTheme;

        const themeBtn = document.getElementById('themeToggleBtn');
        if (themeBtn) {
            themeBtn.addEventListener('click', () => applyTheme(document.documentElement.classList.contains('dark') ? 'light' : 'dark'));
        }
        applyTheme(localStorage.theme || 'system');

        // Profile overlay
        const overlay = document.getElementById('profileOverlay');
        const headerProfileBtn = document.getElementById('headerProfileBtn');
        const closeBtn = document.getElementById('closeProfileOverlay');
        const logoutBtn = document.getElementById('logoutBtn');

        if (headerProfileBtn && overlay) headerProfileBtn.addEventListener('click', () => overlay.classList.remove('hidden'));
        if (closeBtn && overlay) closeBtn.addEventListener('click', () => overlay.classList.add('hidden'));
        if (overlay) overlay.addEventListener('click', (e) => { if (e.target === overlay) overlay.classList.add('hidden'); });
        if (logoutBtn) logoutBtn.addEventListener('click', () => { window.location.href = '/auth/logout'; });
    });
</script>
</body>
</html>