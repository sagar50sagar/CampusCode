<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Faculty - HOD Dashboard</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&display=swap"
        rel="stylesheet" />
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="/css/shared.css">
    <script>
        tailwind.config = { darkMode: 'class', theme: { extend: { fontFamily: { sans: ["Poppins", "sans-serif"] }, colors: { primary: { 50: "#E7F0FA", 100: "#D0E1F5", 200: "#7BA4D0", 300: "#4D84C0", 400: "#2E5E99", 500: "#1E4A7A", 600: "#0D2440" }, dark: { bg: "#111827", card: "#1F2937", text: "#F9FAFB", border: "#374151" } } } } };
    </script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/xlsx/0.18.5/xlsx.full.min.js"></script>
    <script src="/js/Hod/index1_logic.js"></script>
</head>

<body
    class="bg-gray-50 dark:bg-gray-900 min-h-screen font-sans transition-colors duration-200 text-gray-800 dark:text-gray-200">
    <div class="flex h-screen overflow-hidden">
        <aside id="mainSidebar"
            class="sidebar w-64 bg-white dark:bg-gray-800 shadow-sm border-r border-gray-200 dark:border-gray-700 flex flex-col h-screen flex-shrink-0 transition-all duration-300 z-50">

            <div class="p-6 flex-shrink-0 flex items-center justify-between h-[88px]">
                <h1
                    class="text-2xl font-bold text-gray-800 dark:text-white flex items-center gap-2 overflow-hidden whitespace-nowrap">
                    <i class="fas fa-code text-primary-500 text-2xl flex-shrink-0"></i>
                    <span id="sidebarLogoText" class="transition-all duration-300 opacity-100">CampusCode</span>
                </h1>
                <button id="sidebarToggleBtn"
                    class="p-1.5 rounded-lg text-gray-400 hover:bg-gray-100 dark:hover:bg-gray-700 hover:text-primary-500 transition-colors focus:outline-none">
                    <i class="fas fa-chevron-left transition-transform duration-300"></i>
                </button>
            </div>

            <nav class="flex-1 space-y-1 overflow-y-auto mt-2 font-sans">

                <a href="/college/hod/dashboard"
                    class="group flex items-center gap-3 px-6 py-3.5 text-sm font-medium transition-all <%= currentPage === 'dashboard' ? 'bg-primary-50 dark:bg-primary-900/20 text-primary-600 dark:text-primary-400 border-r-4 border-primary-600 dark:border-primary-400' : 'text-gray-600 dark:text-gray-300 hover:bg-gray-50 dark:hover:bg-gray-700 border-r-4 border-transparent' %>">
                    <i class="fas fa-home w-5 text-center text-lg"></i>
                    <span class="whitespace-nowrap">Dashboard</span>
                </a>

                <a href="/college/hod/problem"
                    class="group flex items-center gap-3 px-6 py-3.5 text-sm font-medium transition-all <%= currentPage === 'problem' ? 'bg-primary-50 dark:bg-primary-900/20 text-primary-600 dark:text-primary-400 border-r-4 border-primary-600 dark:border-primary-400' : 'text-gray-600 dark:text-gray-300 hover:bg-gray-50 dark:hover:bg-gray-700 border-r-4 border-transparent' %>">
                    <i class="fas fa-tasks w-5 text-center text-lg"></i>
                    <span class="whitespace-nowrap">Problems</span>
                </a>

                <a href="/college/hod/contest"
                    class="group flex items-center gap-3 px-6 py-3.5 text-sm font-medium transition-all <%= currentPage === 'contest' ? 'bg-primary-50 dark:bg-primary-900/20 text-primary-600 dark:text-primary-400 border-r-4 border-primary-600 dark:border-primary-400' : 'text-gray-600 dark:text-gray-300 hover:bg-gray-50 dark:hover:bg-gray-700 border-r-4 border-transparent' %>">
                    <i class="fas fa-trophy w-5 text-center text-lg"></i>
                    <span class="whitespace-nowrap">Contests</span>
                </a>

                <a href="/college/hod/faculty"
                    class="group flex items-center gap-3 px-6 py-3.5 text-sm font-medium transition-all <%= currentPage === 'faculty' ? 'bg-primary-50 dark:bg-primary-900/20 text-primary-600 dark:text-primary-400 border-r-4 border-primary-600 dark:border-primary-400' : 'text-gray-600 dark:text-gray-300 hover:bg-gray-50 dark:hover:bg-gray-700 border-r-4 border-transparent' %>">
                    <i class="fas fa-users w-5 text-center text-lg"></i>
                    <span class="whitespace-nowrap">Faculty</span>
                </a>

                <a href="/college/hod/student"
                    class="group flex items-center gap-3 px-6 py-3.5 text-sm font-medium transition-all <%= currentPage === 'student' ? 'bg-primary-50 dark:bg-primary-900/20 text-primary-600 dark:text-primary-400 border-r-4 border-primary-600 dark:border-primary-400' : 'text-gray-600 dark:text-gray-300 hover:bg-gray-50 dark:hover:bg-gray-700 border-r-4 border-transparent' %>">
                    <i class="fas fa-user-graduate w-5 text-center text-lg"></i>
                    <span class="whitespace-nowrap">Students</span>
                </a>

                <a href="/college/hod/community"
                    class="group flex items-center gap-3 px-6 py-3.5 text-sm font-medium transition-all <%= currentPage === 'community' ? 'bg-primary-50 dark:bg-primary-900/20 text-primary-600 dark:text-primary-400 border-r-4 border-primary-600 dark:border-primary-400' : 'text-gray-600 dark:text-gray-300 hover:bg-gray-50 dark:hover:bg-gray-700 border-r-4 border-transparent' %>">
                    <i class="fas fa-comments w-5 text-center text-lg"></i>
                    <span class="whitespace-nowrap">Community</span>
                </a>

                <a href="/college/hod/report"
                    class="group flex items-center gap-3 px-6 py-3.5 text-sm font-medium transition-all <%= currentPage === 'report' ? 'bg-primary-50 dark:bg-primary-900/20 text-primary-600 dark:text-primary-400 border-r-4 border-primary-600 dark:border-primary-400' : 'text-gray-600 dark:text-gray-300 hover:bg-gray-50 dark:hover:bg-gray-700 border-r-4 border-transparent' %>">
                    <i class="fas fa-chart-pie w-5 text-center text-lg"></i>
                    <span class="whitespace-nowrap">Reports</span>
                </a>

            </nav>

            <div
                class="p-4 space-y-1 border-t border-gray-200 dark:border-gray-700 bg-white dark:bg-gray-800 flex-shrink-0">

                <a href="/college/hod/help"
                    class="group flex items-center gap-3 px-6 py-3.5 text-sm font-medium transition-all rounded-lg <%= currentPage === 'help' ? 'bg-primary-50 dark:bg-primary-900/20 text-primary-600 dark:text-primary-400' : 'text-gray-600 dark:text-gray-300 hover:bg-gray-50 dark:hover:bg-gray-700' %>">
                    <i class="far fa-question-circle w-5 text-center text-lg group-hover:scale-110 transition-transform"></i>
                    <span class="whitespace-nowrap">Help & Support</span>
                </a>

                <a href="/college/hod/settings"
                    class="group flex items-center gap-3 px-6 py-3.5 text-sm font-medium transition-all rounded-lg <%= currentPage === 'settings' ? 'bg-primary-50 dark:bg-primary-900/20 text-primary-600 dark:text-primary-400' : 'text-gray-600 dark:text-gray-300 hover:bg-gray-50 dark:hover:bg-gray-700' %>">
                    <i class="fas fa-cog w-5 text-center text-lg group-hover:rotate-90 transition-transform duration-500"></i>
                    <span class="whitespace-nowrap">Settings</span>
                </a>

            </div>
        </aside>
        <div class="flex-1 overflow-y-auto">
            <header class="bg-white dark:bg-gray-800 shadow-sm transition-colors duration-200 sticky top-0 z-20">
                <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-3 flex justify-between items-center">
                    <h2 class="text-xl font-bold text-gray-800 dark:text-white ml-2">Faculty Management</h2>
                    <div class="ml-4 flex items-center gap-3">
                        <button id="themeToggleBtn"
                            class="p-2 rounded-full text-gray-500 hover:text-gray-700 dark:text-gray-400 dark:hover:text-gray-200 focus:outline-none transition-transform active:scale-95"><i
                                class="fas fa-moon text-xl"></i></button>
                        <div class="relative">
                            <button id="notificationBtn"
                                class="p-2 rounded-full text-gray-500 dark:text-gray-400 hover:text-gray-700 dark:hover:text-gray-200 focus:outline-none transition-transform active:scale-95">
                                <i class="fas fa-bell text-xl"></i>
                                <span
                                    class="absolute top-0 right-0 h-2.5 w-2.5 rounded-full bg-red-500 border-2 border-white dark:border-gray-800"></span>
                            </button>
                        </div>
                        <button id="headerProfileBtn"
                            class="ml-2 flex items-center gap-3 p-1 pr-3 rounded-full hover:bg-gray-100 dark:hover:bg-gray-700 transition-colors">
                            <div
                                class="h-9 w-9 rounded-full bg-primary-500 flex items-center justify-center text-white font-bold text-sm">
                                <%= user.fullName.split(' ').map(n => n[0]).join('') %></div>
                            <span class="text-sm font-medium text-gray-700 dark:text-gray-200 hidden sm:block"><%= user.fullName %></span>
                        </button>
                    </div>
                </div>
            </header>
            <main class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-6 relative">
                <!-- SECTION: FACULTY MANAGEMENT (NEW) -->
                <div id="section-manage-faculty" class="content-section">

                    <!-- Stats Overview -->
                    <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-8">
                        <div
                            class="bg-white dark:bg-gray-800 p-6 rounded-2xl shadow-sm border border-gray-100 dark:border-gray-700 flex items-center gap-4 hover:shadow-md transition-shadow">
                            <div
                                class="w-12 h-12 rounded-xl bg-blue-100 dark:bg-blue-900/30 flex items-center justify-center text-blue-600 dark:text-blue-400">
                                <i class="fas fa-chalkboard-teacher text-xl"></i>
                            </div>
                            <div>
                                <p class="text-sm text-gray-500 dark:text-gray-400 font-medium">Department Faculty</p>
                                <h3 class="text-2xl font-bold text-gray-800 dark:text-white"><%= departmentFaculty.length %></h3>
                            </div>
                        </div>
                    </div>

                    <!-- Success / Error Banner -->
                    <% if (typeof created !== 'undefined' && created) { %>
                    <div class="mb-4 bg-green-50 dark:bg-green-900/30 border-l-4 border-green-500 p-4 rounded-r-lg flex items-center gap-3">
                        <i class="fas fa-check-circle text-green-500"></i>
                        <p class="text-sm text-green-700 dark:text-green-300 font-medium">Faculty created successfully! Temporary password: <code class="font-bold bg-green-100 dark:bg-green-900/50 px-1 rounded">changeme123</code></p>
                    </div>
                    <% } %>
                    <% if (typeof error !== 'undefined' && error) { %>
                    <div class="mb-4 bg-red-50 dark:bg-red-900/30 border-l-4 border-red-500 p-4 rounded-r-lg flex items-center gap-3">
                        <i class="fas fa-exclamation-circle text-red-500"></i>
                        <p class="text-sm text-red-700 dark:text-red-300 font-medium"><%= error %></p>
                    </div>
                    <% } %>

                    <div
                        class="bg-white dark:bg-gray-800 rounded-2xl shadow-sm border border-gray-100 dark:border-gray-700 overflow-hidden">
                        <!-- Header & Filters -->
                        <div
                            class="p-6 border-b border-gray-100 dark:border-gray-700 flex flex-col md:flex-row justify-between items-center gap-4 bg-gray-50/50 dark:bg-gray-700/20">
                            <div class="relative w-full md:w-72">
                                <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
                                    <i class="fas fa-search text-gray-400"></i>
                                </div>
                                <input type="text" id="facultySearchInput"
                                    class="block w-full pl-10 pr-4 py-2.5 border border-gray-200 dark:border-gray-600 rounded-xl focus:ring-2 focus:ring-primary-500 bg-white dark:bg-gray-800 text-sm text-gray-900 dark:text-white placeholder-gray-400 transition-shadow"
                                    placeholder="Search by name, email, or role...">
                            </div>

                            <div class="w-full md:w-auto">
                                <select id="facultySubjectFilter"
                                    class="w-full md:w-auto rounded-xl border border-gray-200 dark:border-gray-600 bg-white dark:bg-gray-800 text-sm p-2.5 text-gray-900 dark:text-white focus:ring-2 focus:ring-primary-500 transition-shadow outline-none cursor-pointer">
                                    <option value="All Subjects">All Subjects</option>
                                    <% dropdownData.subjects.forEach(subject => { %>
                                        <option value="<%= subject %>"><%= subject %></option>
                                    <% }) %>
                                </select>
                            </div>

                            <div class="flex items-center gap-3 w-full md:w-auto">
                                <button id="btn-export-faculty"
                                    class="group p-2.5 rounded-xl border border-gray-200 dark:border-gray-600 hover:bg-gray-50 dark:hover:bg-gray-700/50 text-gray-600 dark:text-gray-300 transition-colors"
                                    title="Export Data">
                                    <i
                                        class="fas fa-download group-hover:text-primary-600 dark:group-hover:text-primary-400"></i>
                                </button>
                                <div class="h-8 w-px bg-gray-200 dark:bg-gray-700 mx-1"></div>
                                <button id="btn-global-search" class="flex items-center gap-2 bg-indigo-600 hover:bg-indigo-700 text-white px-5 py-2.5 rounded-xl text-sm font-semibold transition-all shadow-md hover:shadow-lg active:scale-95">
                                    <i class="fas fa-search-plus"></i>
                                    <span>Global Search</span>
                                </button>
                                <button id="btn-add-faculty"
                                    class="flex items-center gap-2 bg-primary-600 hover:bg-primary-700 text-white px-5 py-2.5 rounded-xl text-sm font-semibold transition-all shadow-md hover:shadow-lg active:scale-95">
                                    <i class="fas fa-plus"></i>
                                    <span>Add Faculty</span>
                                </button>
                            </div>
                        </div>

                        <!-- Enhanced Faculty Table -->
                        <div class="overflow-x-auto">
                            <table class="w-full text-left text-sm">
                                <thead
                                    class="bg-gray-50/80 dark:bg-gray-700/50 text-xs uppercase tracking-wider text-gray-500 dark:text-gray-400 font-semibold">
                                    <tr>
                                        <th class="px-6 py-4 rounded-tl-lg">Faculty Member</th>
                                        <th class="px-6 py-4">Domain & Role</th>
                                        <th class="px-6 py-4">Academic Assignments</th>
                                        <th class="px-6 py-4 text-right rounded-tr-lg">Actions</th>
                                    </tr>
                                </thead>
                                <tbody class="divide-y divide-gray-100 dark:divide-gray-700">
                                    <% departmentFaculty.forEach(f => { %>
                                    <tr class="group hover:bg-gray-50 dark:hover:bg-gray-800/50 transition-colors">
                                        <td class="px-6 py-4">
                                            <div class="flex items-center gap-4">
                                                <div
                                                    class="w-10 h-10 rounded-full bg-gradient-to-br from-blue-100 to-indigo-100 dark:from-blue-900/40 dark:to-indigo-900/40 flex items-center justify-center text-blue-600 dark:text-blue-300 font-bold text-sm shadow-sm">
                                                    <%= f.fullName.split(' ').map(n => n[0]).join('') %>
                                                </div>
                                                <div>
                                                    <span
                                                        class="faculty-name-trigger subject-count-trigger block text-sm font-semibold text-gray-900 dark:text-white hover:text-primary-600 dark:hover:text-primary-400 cursor-pointer transition-colors"
                                                        data-name="<%= f.fullName %>" data-email="<%= f.email %>" data-dept="<%= f.department %>" data-role="<%= f.role %>" data-assigned="<%= f.assignments || '' %>"
                                                        data-subjects='<%= JSON.stringify((f.assignments || "").split(",")) %>'>
                                                        <%= f.fullName %>
                                                    </span>
                                                    <span
                                                        class="text-xs text-gray-500 dark:text-gray-400"><%= f.email %></span>
                                                </div>
                                            </div>
                                        </td>
                                        <td class="px-6 py-4">
                                            <div class="flex flex-col items-start gap-1">
                                                <span
                                                    class="px-2 py-0.5 rounded text-[10px] font-bold uppercase tracking-wide <%= f.role === 'hos' ? 'bg-purple-100 text-purple-700 dark:bg-purple-900/30 dark:text-purple-300' : 'bg-blue-100 text-blue-700 dark:bg-blue-900/30 dark:text-blue-300' %> border border-current">
                                                    <%= f.role.toUpperCase() %>
                                                </span>
                                                <span class="text-xs text-gray-600 dark:text-gray-300"><%= f.department %></span>
                                            </div>
                                        </td>
                                        <td class="px-6 py-4">
                                            <% if (f.assignments) { %>
                                                <div class="flex flex-wrap gap-1">
                                                    <% f.assignments.split(',').forEach(a => { %>
                                                        <span class="px-2 py-0.5 rounded-full bg-indigo-50 dark:bg-indigo-900/20 text-indigo-600 dark:text-indigo-400 text-[10px] font-medium border border-indigo-100 dark:border-indigo-800">
                                                            <%= a %>
                                                        </span>
                                                    <% }) %>
                                                </div>
                                            <% } else { %>
                                                <span class="text-xs text-gray-400 italic text-nowrap">No Assignments</span>
                                            <% } %>
                                        </td>
                                        <td class="px-6 py-4 text-nowrap">
                                            <div class="flex items-center justify-end gap-2">
                                                <% if (f.department === user.department) { %>
                                                    <% if (f.status === 'pending') { %>
                                                        <button onclick="confirmVerify('<%= f.id %>')"
                                                            class="inline-flex items-center gap-1 px-3 py-1.5 rounded-lg bg-green-500 hover:bg-green-600 text-white text-[10px] font-bold uppercase transition-all shadow-sm"
                                                            title="Verify Faculty Member">
                                                            <i class="fas fa-check text-xs"></i> Verify
                                                        </button>
                                                    <% } %>
                                                    <button onclick='openUnifiedModal("<%= f.id %>", <%- JSON.stringify(f.fullName) %>, "<%= f.role %>", <%- JSON.stringify(f.hosSubject || "") %>)'
                                                        class="inline-flex items-center gap-1 px-3 py-1.5 rounded-lg bg-primary-600 hover:bg-primary-700 text-white text-[10px] font-bold uppercase transition-all shadow-sm"
                                                        title="Manage Assignments & Role">
                                                        <i class="fas fa-cog text-xs"></i> Manage
                                                    </button>
                                                    <button onclick='editFaculty("<%= f.id %>", <%- JSON.stringify(f.fullName) %>, "<%= f.email %>", "<%= f.joiningDate || "" %>")'
                                                        class="w-8 h-8 flex items-center justify-center rounded-lg bg-blue-500/10 hover:bg-blue-500/20 text-blue-600 dark:text-blue-400 transition-all"
                                                        title="Edit Profile">
                                                        <i class="fas fa-edit text-xs"></i>
                                                    </button>
                                                    <button onclick="deleteFaculty('<%= f.id %>')"
                                                        class="w-8 h-8 flex items-center justify-center rounded-lg bg-red-500/10 hover:bg-red-500/20 text-red-600 dark:text-red-400 transition-all"
                                                        title="Delete Faculty Account">
                                                        <i class="fas fa-trash-alt text-xs"></i>
                                                    </button>
                                                <% } else { %>
                                                    <span class="px-2 py-1 rounded-lg bg-gray-100 dark:bg-gray-800 text-gray-400 text-[10px] uppercase font-bold border border-gray-200 dark:border-gray-700 select-none">
                                                        Read Only
                                                    </span>
                                                <% } %>
                                            </div>
                                        </td>
                                    </tr>
                                    <% }) %>
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>

                <!-- Faculty Form (Hidden) -->
                <div id="faculty-form-view" class="hidden">
                    <div class="max-w-3xl mx-auto">
                        <div
                            class="bg-white dark:bg-gray-800 rounded-xl shadow-lg border border-gray-100 dark:border-gray-700 overflow-hidden">
                            <!-- Form Header -->
                            <div
                                class="px-8 py-6 border-b border-gray-100 dark:border-gray-700 flex items-center justify-between bg-gray-50/50 dark:bg-gray-700/30">
                                <div class="flex items-center gap-4">
                                    <button id="btn-back-to-faculty-list"
                                        class="w-8 h-8 rounded-full bg-white dark:bg-gray-600 shadow-sm flex items-center justify-center text-gray-500 hover:text-primary-600 transition-colors">
                                        <i class="fas fa-arrow-left text-sm"></i>
                                    </button>
                                    <div>
                                        <h2 class="text-xl font-bold text-gray-800 dark:text-white">Add New Faculty</h2>
                                        <p class="text-sm text-gray-500 dark:text-gray-400">Enter faculty details to
                                            register</p>
                                    </div>
                                </div>
                            </div>

                            <div class="p-8">
                                <form action="/college/hod/faculty/create" method="POST" class="space-y-8">
                                    <!-- Personal Info Section -->
                                    <div>
                                        <h3
                                            class="text-xs font-bold text-gray-400 uppercase tracking-wider mb-4 border-b border-gray-100 dark:border-gray-700 pb-2">
                                            Personal Information
                                        </h3>
                                        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                                            <div class="md:col-span-2">
                                                <label
                                                    class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1.5">Full
                                                    Name</label>
                                                <div class="relative">
                                                    <div
                                                        class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
                                                        <i class="fas fa-user text-gray-400"></i>
                                                    </div>
                                                    <input type="text" name="fullName"
                                                        class="pl-10 w-full rounded-lg border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-700 text-sm p-2.5 text-gray-900 dark:text-white focus:ring-2 focus:ring-primary-500 transition-shadow"
                                                        placeholder="e.g. Dr. Vishnu Gupta" required>
                                                </div>
                                            </div>

                                            <div>
                                                <label
                                                    class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1.5">Email
                                                    Address</label>
                                                <div class="relative">
                                                    <div
                                                        class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
                                                        <i class="fas fa-envelope text-gray-400"></i>
                                                    </div>
                                                    <input type="email" name="email"
                                                        class="pl-10 w-full rounded-lg border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-700 text-sm p-2.5 text-gray-900 dark:text-white focus:ring-2 focus:ring-primary-500 transition-shadow"
                                                        placeholder="e.g. vishnu.gupta@college.edu" required>
                                                </div>
                                            </div>

                                            <div>
                                                <label
                                                    class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1.5">Phone
                                                    Number</label>
                                                <div class="relative">
                                                    <div
                                                        class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
                                                        <i class="fas fa-phone text-gray-400"></i>
                                                    </div>
                                                    <input type="text" name="mobile"
                                                        class="pl-10 w-full rounded-lg border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-700 text-sm p-2.5 text-gray-900 dark:text-white focus:ring-2 focus:ring-primary-500 transition-shadow"
                                                        placeholder="e.g. +91 98765 43210">
                                                </div>
                                            </div>
                                        </div>
                                    </div>

                                    <!-- Professional Info Section -->
                                    <div>
                                        <h3
                                            class="text-xs font-bold text-gray-400 uppercase tracking-wider mb-4 border-b border-gray-100 dark:border-gray-700 pb-2">
                                            Professional Details
                                        </h3>
                                        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                                            <div>
                                                <label
                                                    class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1.5">Department</label>
                                                <div class="relative">
                                                    <div
