<!DOCTYPE html>
<html lang="en" class="<%= user.theme === 'dark' ? 'dark' : '' %>">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Pending Contests Approval | CampusCode HOD</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
    <link rel="stylesheet" href="/css/shared.css">
    <link rel="stylesheet" href="/css/hod/style.css">
    <script>
        tailwind.config = {
            darkMode: 'class',
            theme: {
                extend: {
                    colors: {
                        primary: {
                            50: '#eff6ff', 100: '#dbeafe', 200: '#bfdbfe', 300: '#93c5fd', 
                            400: '#60a5fa', 500: '#3b82f6', 600: '#2563eb', 700: '#1d4ed8',
                        }
                    }
                }
            }
        }
    </script>
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap');
        body { font-family: 'Inter', sans-serif; }
        .glass-card {
            background: rgba(255, 255, 255, 0.05);
            backdrop-filter: blur(10px);
            border: 1px solid rgba(255, 255, 255, 0.1);
        }
        .dark .glass-card {
            background: rgba(15, 23, 42, 0.4);
        }
    </style>
</head>
<body class="bg-[#0f172a] text-gray-100 min-h-screen font-sans">
    
    <div class="flex h-screen overflow-hidden">
        <!-- Main Content Area (No Sidebar) -->
        <div class="flex-1 flex flex-col overflow-hidden">
            
            <!-- Top Navigation Bar -->
            <header class="h-16 flex items-center px-8 border-b border-gray-800 bg-[#0f172a] justify-between z-10">
                <div class="flex items-center gap-4">
                    <h1 class="text-xl font-bold tracking-tight text-white flex items-center gap-2">
                        <i class="fas fa-code text-blue-500"></i>
                        <span>CampusCode</span>
                    </h1>
                </div>
                <div class="flex items-center gap-6">
                    <div class="relative group">
                        <i class="fas fa-cog text-gray-400 cursor-pointer hover:text-white transition-colors"></i>
                    </div>
                    <div class="relative">
                        <i class="fas fa-bell text-gray-400 cursor-pointer hover:text-white transition-colors"></i>
                        <span class="absolute -top-1 -right-1 w-2 h-2 bg-red-500 rounded-full"></span>
                    </div>
                    <div class="flex items-center gap-3 pl-4 border-l border-gray-800">
                    <div class="flex items-center gap-3 pl-4 border-l border-gray-800">
                        <div class="w-8 h-8 rounded-full bg-blue-600 flex items-center justify-center text-xs font-bold ring-2 ring-blue-500/20">
                            <%= user.fullName.split(' ').map(n => n[0]).join('') %>
                        </div>
                        <span class="text-sm font-medium text-gray-300"><%= user.fullName %></span>
                    </div>
                </div>
            </header>

            <main class="flex-1 overflow-y-auto bg-[#0a0f1e] p-8">
                <div class="max-w-[1400px] mx-auto">
                    
                    <!-- Page Header -->
                    <div class="flex items-start justify-between mb-10">
                        <div class="flex items-center gap-4">
                            <div class="w-12 h-12 rounded-xl bg-pink-500/10 flex items-center justify-center text-pink-500 text-2xl border border-pink-500/20">
                                <i class="fas fa-hourglass-half"></i>
                            </div>
                            <div>
                                <h1 class="text-2xl font-bold text-white mb-1 tracking-tight">Pending Contests Approval</h1>
                                <p class="text-gray-400 text-sm">Review and approve contests submitted by faculty members</p>
                            </div>
                        </div>
                        <div class="flex items-center gap-4">
                            <a href="/college/hod/dashboard" class="px-4 py-2 rounded-lg bg-gray-800 hover:bg-gray-700 text-gray-300 text-sm font-semibold border border-gray-700 transition-all flex items-center gap-2">
                                <i class="fas fa-arrow-left"></i> Back to Dashboard
                            </a>
                            <button onclick="bulkApprove()" class="px-4 py-2 rounded-lg bg-emerald-600 hover:bg-emerald-500 text-white text-sm font-bold shadow-lg shadow-emerald-500/20 transition-all flex items-center gap-2">
                                <i class="fas fa-check-double"></i> Bulk Approve
                            </button>
                            <button class="px-4 py-2 rounded-lg bg-blue-600 hover:bg-blue-500 text-white text-sm font-bold shadow-lg shadow-blue-500/20 transition-all flex items-center gap-2">
                                <i class="fas fa-file-export"></i> Export
                            </button>
                        </div>
                    </div>

                    <!-- Stats Grid -->
                    <div class="grid grid-cols-1 md:grid-cols-3 lg:grid-cols-5 gap-6 mb-10">
                        <div class="bg-gray-800/40 border border-gray-700 p-6 rounded-2xl flex items-center justify-between group hover:border-blue-500/50 transition-all cursor-default">
                            <div>
                                <p class="text-gray-400 text-xs font-bold uppercase tracking-wider mb-2">Total Pending</p>
                                <p class="text-3xl font-bold text-white"><%= stats.pendingCount %></p>
                            </div>
                            <div class="w-12 h-12 rounded-2xl bg-gray-900/50 flex items-center justify-center text-pink-500 border border-gray-700">
                                <i class="fas fa-hourglass-half text-xl"></i>
                            </div>
                        </div>
                        <div class="bg-gray-800/40 border border-gray-700 p-6 rounded-2xl flex items-center justify-between group hover:border-emerald-500/50 transition-all cursor-default">
                            <div>
                                <p class="text-gray-400 text-xs font-bold uppercase tracking-wider mb-2">Approved</p>
                                <p class="text-3xl font-bold text-white"><%= stats.approvedCount %></p>
                            </div>
                            <div class="w-12 h-12 rounded-2xl bg-gray-900/50 flex items-center justify-center text-emerald-500 border border-gray-700">
                                <i class="fas fa-check-circle text-xl"></i>
                            </div>
                        </div>
                        <div class="bg-gray-800/40 border border-gray-700 p-6 rounded-2xl flex items-center justify-between group hover:border-red-500/50 transition-all cursor-default">
                            <div>
                                <p class="text-gray-400 text-xs font-bold uppercase tracking-wider mb-2">Rejected</p>
                                <p class="text-3xl font-bold text-white"><%= stats.rejectedCount %></p>
                            </div>
                            <div class="w-12 h-12 rounded-2xl bg-gray-900/50 flex items-center justify-center text-red-500 border border-gray-700">
                                <i class="fas fa-times-circle text-xl"></i>
                            </div>
                        </div>
                        <div class="bg-gray-800/40 border border-gray-700 p-6 rounded-2xl flex items-center justify-between group hover:border-blue-500/50 transition-all cursor-default">
                            <div>
                                <p class="text-gray-400 text-xs font-bold uppercase tracking-wider mb-2">Upcoming</p>
                                <p class="text-3xl font-bold text-white"><%= stats.upcomingCount %></p>
                            </div>
                            <div class="w-12 h-12 rounded-2xl bg-gray-900/50 flex items-center justify-center text-blue-500 border border-gray-700">
                                <i class="fas fa-calendar-alt text-xl"></i>
                            </div>
                        </div>
                        <div class="bg-gray-800/40 border border-gray-700 p-6 rounded-2xl flex items-center justify-between group hover:border-orange-500/50 transition-all cursor-default">
                            <div>
                                <p class="text-gray-400 text-xs font-bold uppercase tracking-wider mb-2">Conflicts</p>
                                <p class="text-3xl font-bold text-white"><%= stats.conflictCount %></p>
                            </div>
                            <div class="w-12 h-12 rounded-2xl bg-gray-900/50 flex items-center justify-center text-orange-500 border border-gray-700">
                                <i class="fas fa-exclamation-triangle text-xl"></i>
                            </div>
                        </div>
                    </div>

                    <!-- Main Content Card -->
                    <div class="bg-[#0f172a] rounded-3xl border border-gray-800 shadow-2xl overflow-hidden">
                        
                        <!-- Tabs -->
                        <div class="flex items-center px-8 border-b border-gray-800 bg-[#161e31]">
                            <a href="?tab=all" class="px-6 py-4 text-sm font-semibold border-b-2 transition-all <%= (!query.tab || query.tab === 'all') ? 'border-blue-500 text-blue-500' : 'border-transparent text-gray-500 hover:text-gray-300' %> flex items-center gap-2">
                                <i class="fas fa-list-ul"></i> All Contests <span class="bg-blue-500/20 text-blue-400 px-2 py-0.5 rounded-full text-[10px]"><%= (stats.pendingCount + stats.approvedCount + stats.rejectedCount) %></span>
                            </a>
                            <a href="?tab=approved" class="px-6 py-4 text-sm font-semibold border-b-2 transition-all <%= query.tab === 'accepted' ? 'border-emerald-500 text-emerald-500' : 'border-transparent text-gray-500 hover:text-gray-300' %> flex items-center gap-2">
                                <i class="fas fa-check"></i> Approved <span class="bg-emerald-500/20 text-emerald-400 px-2 py-0.5 rounded-full text-[10px]"><%= stats.approvedCount %></span>
                            </a>
                            <a href="?tab=rejected" class="px-6 py-4 text-sm font-semibold border-b-2 transition-all <%= query.tab === 'rejected' ? 'border-red-500 text-red-500' : 'border-transparent text-gray-500 hover:text-gray-300' %> flex items-center gap-2">
                                <i class="fas fa-times"></i> Rejected <span class="bg-red-500/20 text-red-400 px-2 py-0.5 rounded-full text-[10px]"><%= stats.rejectedCount %></span>
                            </a>
                                <i class="fas fa-play"></i> Active <span class="bg-indigo-500/20 text-indigo-400 px-2 py-0.5 rounded-full text-[10px]"><%= stats.approvedCount %></span>
                            </a>
                            <a href="?tab=conflicts" class="px-6 py-4 text-sm font-semibold border-b-2 transition-all <%= query.tab === 'conflicts' ? 'border-orange-500 text-orange-500' : 'border-transparent text-gray-500 hover:text-gray-300' %> flex items-center gap-2">
                                <i class="fas fa-exclamation-triangle"></i> Conflicts <span class="bg-orange-500/20 text-orange-400 px-2 py-0.5 rounded-full text-[10px]"><%= stats.conflictCount %></span>
                            </a>
                        </div>

                        <!-- Filters -->
                        <div class="p-8 bg-[#0f172a]">
                            <form id="filterForm" class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-5 gap-6">
                                <div>
                                    <label class="block text-[10px] font-bold text-gray-500 uppercase tracking-widest mb-2">Subject</label>
                                    <select name="subject" class="w-full bg-[#1e293b] border border-gray-700 rounded-xl px-4 py-2.5 text-sm text-white focus:outline-none focus:ring-2 focus:ring-blue-500/50 transition-all cursor-pointer appearance-none">
                                        <option>All Subjects</option>
                                        <% subjects.forEach(s => { %>
                                            <option <%= query.subject === s ? 'selected' : '' %>><%= s %></option>
                                        <% }) %>
                                    </select>
                                </div>
                                <div>
                                    <label class="block text-[10px] font-bold text-gray-500 uppercase tracking-widest mb-2">Contest Type</label>
                                    <select name="type" class="w-full bg-[#1e293b] border border-gray-700 rounded-xl px-4 py-2.5 text-sm text-white focus:outline-none focus:ring-2 focus:ring-blue-500/50 transition-all cursor-pointer appearance-none">
                                        <option>All Types</option>
                                        <% types.forEach(t => { %>
                                            <option <%= query.type === t ? 'selected' : '' %>><%= t %></option>
                                        <% }) %>
                                    </select>
                                </div>
                                <div>
                                    <label class="block text-[10px] font-bold text-gray-500 uppercase tracking-widest mb-2">Start Date From</label>
                                    <input type="date" name="dateFrom" value="<%= query.dateFrom %>" class="w-full bg-[#1e293b] border border-gray-700 rounded-xl px-4 py-2.5 text-sm text-white focus:outline-none focus:ring-2 focus:ring-blue-500/50 transition-all cursor-pointer">
                                </div>
                                <div>
                                    <label class="block text-[10px] font-bold text-gray-500 uppercase tracking-widest mb-2">Start Date To</label>
                                    <input type="date" name="dateTo" value="<%= query.dateTo %>" class="w-full bg-[#1e293b] border border-gray-700 rounded-xl px-4 py-2.5 text-sm text-white focus:outline-none focus:ring-2 focus:ring-blue-500/50 transition-all cursor-pointer">
                                </div>
                                <div>
                                    <label class="block text-[10px] font-bold text-gray-500 uppercase tracking-widest mb-2">Approved By HOS</label>
                                    <select name="hos_approved" class="w-full bg-[#1e293b] border border-gray-700 rounded-xl px-4 py-2.5 text-sm text-white focus:outline-none focus:ring-2 focus:ring-blue-500/50 transition-all cursor-pointer appearance-none">
                                        <option>All</option>
                                        <option value="Yes" <%= query.hos_approved === 'Yes' ? 'selected' : '' %>>Yes</option>
                                        <option value="No" <%= query.hos_approved === 'No' ? 'selected' : '' %>>No</option>
                                    </select>
                                </div>
                                <div class="lg:col-span-1 flex items-end gap-3">
                                    <button type="submit" class="flex-1 px-6 py-2.5 bg-blue-600 hover:bg-blue-500 text-white text-sm font-bold rounded-xl shadow-lg shadow-blue-500/20 transition-all flex items-center justify-center gap-2">
                                        <i class="fas fa-filter text-xs"></i> Apply Filters
                                    </button>
                                    <a href="/college/hod/pending-contests" class="px-6 py-2.5 bg-gray-800 hover:bg-gray-700 text-gray-300 text-sm font-bold rounded-xl border border-gray-700 transition-all flex items-center justify-center gap-2">
                                        <i class="fas fa-undo text-xs"></i> Reset
                                    </a>
                                </div>
                            </form>
                        </div>

                        <!-- Table Section -->
                        <div class="overflow-x-auto">
                            <table class="w-full border-collapse">
                                <thead>
                                    <tr class="bg-[#161e31] border-b border-gray-800">
                                        <th class="p-6 text-left w-12">
                                            <input type="checkbox" id="selectAll" class="w-4 h-4 rounded bg-gray-700 border-gray-600 text-blue-500 focus:ring-blue-500/20 focus:ring-offset-0 transition-all cursor-pointer">
                                        </th>
                                        <th class="p-6 text-[10px] font-bold text-gray-500 uppercase tracking-widest text-left">Contest Name</th>
                                        <th class="p-6 text-[10px] font-bold text-gray-500 uppercase tracking-widest text-left">Type</th>
                                        <th class="p-6 text-[10px] font-bold text-gray-500 uppercase tracking-widest text-left">Section</th>
                                        <th class="p-6 text-[10px] font-bold text-gray-500 uppercase tracking-widest text-left">Subject</th>
                                        <th class="p-6 text-[10px] font-bold text-gray-500 uppercase tracking-widest text-left">Time Slot</th>
                                        <th class="p-6 text-[10px] font-bold text-gray-500 uppercase tracking-widest text-left">Start Date</th>
                                        <th class="p-6 text-[10px] font-bold text-gray-500 uppercase tracking-widest text-center">Status</th>
                                        <th class="p-6 text-[10px] font-bold text-gray-500 uppercase tracking-widest text-center">Actions</th>
                                    </tr>
                                </thead>
                                <tbody class="divide-y divide-gray-800/50">
                                    <% if (pendingContests.length === 0) { %>
                                        <tr>
                                            <td colspan="9" class="p-20 text-center">
                                                <div class="flex flex-col items-center gap-4">
                                                    <div class="w-16 h-16 rounded-full bg-gray-800/50 flex items-center justify-center text-gray-600 border border-gray-700">
                                                        <i class="fas fa-search text-2xl"></i>
                                                    </div>
                                                    <div>
                                                        <p class="text-gray-400 font-medium">No contests found matching your criteria</p>
                                                        <p class="text-gray-500 text-xs mt-1">Try adjusting your filters or search terms</p>
                                                    </div>
                                                </div>
                                            </td>
                                        </tr>
                                    <% } %>
                                    <% pendingContests.forEach(c => { %>
                                        <tr class="hover:bg-[#161e31]/30 transition-all group">
                                            <td class="p-6 border-b border-gray-800/50">
                                                <input type="checkbox" class="contest-checkbox w-4 h-4 rounded bg-gray-700 border-gray-600 text-blue-500 focus:ring-blue-500/20 transition-all cursor-pointer" data-id="<%= c.id %>">
                                            </td>
                                            <td class="p-6 border-b border-gray-800/50">
                                                <div class="flex flex-col gap-1">
                                                    <span class="text-white font-semibold text-sm group-hover:text-blue-400 transition-colors"><%= c.title %></span>
                                                    <% if (c.conflicts && c.conflicts.length > 0) { %>
                                                        <div class="flex items-center gap-1.5 text-[9px] font-black uppercase tracking-widest bg-red-500/10 text-red-500 px-2 py-0.5 rounded-md border border-red-500/20 w-fit">
                                                            <i class="fas fa-exclamation-triangle text-[8px]"></i> CONFLICT
                                                        </div>
                                                    <% } %>
                                                </div>
                                            </td>
                                            <td class="p-6 border-b border-gray-800/50">
                                                <span class="px-2.5 py-1 rounded-full text-[10px] font-bold bg-orange-500/10 text-orange-400 border border-orange-500/20 uppercase"><%= c.type || 'Competition' %></span>
                                            </td>
                                            <td class="p-6 border-b border-gray-800/50 text-sm text-gray-400 font-medium"><%= c.section || 'All' %></td>
                                            <td class="p-6 border-b border-gray-800/50 text-sm text-gray-400 font-medium"><%= c.subject || 'N/A' %></td>
                                            <td class="p-6 border-b border-gray-800/50 text-xs text-gray-400 font-mono">
                                                <%= new Date(c.startDate).toLocaleTimeString([], {hour: '2-digit', minute:'2-digit'}) %> - <%= new Date(c.endDate).toLocaleTimeString([], {hour: '2-digit', minute:'2-digit'}) %>
                                            </td>
                                            <td class="p-6 border-b border-gray-800/50 text-sm text-gray-400 font-medium">
                                                <%= new Date(c.startDate).toLocaleDateString() %>
                                            </td>
                                            <td class="p-6 border-b border-gray-800/50 text-center">
                                                <% if (c.status === 'accepted') { %>
                                                    <div class="flex items-center justify-center gap-1.5">
                                                        <span class="w-2 h-2 rounded-full bg-emerald-500"></span>
                                                        <span class="text-xs font-bold text-emerald-400 uppercase tracking-tighter">Accepted</span>
                                                    </div>
                                                <% } else if (c.status === 'rejected') { %>
                                                    <div class="flex items-center justify-center gap-1.5">
                                                        <span class="w-2 h-2 rounded-full bg-red-500"></span>
                                                        <span class="text-xs font-bold text-red-400 uppercase tracking-tighter">Rejected</span>
                                                    </div>
                                                <% } else if (c.hos_verified && !c.hod_verified) { %>
                                                    <div class="flex flex-col items-center gap-1">
                                                        <span class="px-2 py-0.5 rounded-full text-[9px] font-black uppercase bg-green-500/10 text-green-400 border border-green-500/20">✓ HOS Done</span>
                                                        <span class="px-2 py-0.5 rounded-full text-[9px] font-black uppercase bg-yellow-500/10 text-yellow-400 border border-yellow-500/20 animate-pulse">⏳ Pending HOD</span>
                                                    </div>
                                                <% } else if (!c.hos_verified && c.hod_verified) { %>
                                                    <div class="flex flex-col items-center gap-1">
                                                        <span class="px-2 py-0.5 rounded-full text-[9px] font-black uppercase bg-yellow-500/10 text-yellow-400 border border-yellow-500/20 animate-pulse">⏳ Pending HOS</span>
                                                        <span class="px-2 py-0.5 rounded-full text-[9px] font-black uppercase bg-green-500/10 text-green-400 border border-green-500/20">✓ HOD Done</span>
                                                    </div>
                                                <% } else { %>
                                                    <div class="flex items-center justify-center gap-1.5">
                                                        <span class="w-2 h-2 rounded-full bg-orange-500 animate-pulse"></span>
                                                        <span class="text-xs font-bold text-orange-400 uppercase tracking-tighter">Pending</span>
                                                    </div>
                                                <% } %>
                                            </td>
                                            <td class="p-6 border-b border-gray-800/50 text-center">
                                                <div class="flex items-center justify-center gap-3">
                                                    <% if (c.status === 'pending') { %>
                                                        <button data-id="<%= c.id %>" data-conflicts="<%= (c.conflicts && c.conflicts.length) || 0 %>" class="approve-contest-btn w-8 h-8 rounded-lg bg-emerald-500/10 hover:bg-emerald-500 text-emerald-500 hover:text-white transition-all border border-emerald-500/20" title="Approve">
                                                            <i class="fas fa-check text-xs"></i>
                                                        </button>
                                                        <button data-id="<%= c.id %>" class="reject-contest-btn w-8 h-8 rounded-lg bg-red-500/10 hover:bg-red-500 text-red-500 hover:text-white transition-all border border-red-500/20" title="Reject">
                                                            <i class="fas fa-times text-xs"></i>
                                                        </button>
                                                    <% } %>
                                                    <button class="w-8 h-8 rounded-lg bg-blue-500/10 hover:bg-blue-500 text-blue-500 hover:text-white transition-all border border-blue-500/20" title="View Details">
                                                        <i class="fas fa-eye text-xs"></i>
                                                    </button>
                                                </div>
                                            </td>
                                        </tr>
                                    <% }) %>
                                </tbody>
                            </table>
                        </div>
                        
                        <!-- Footer -->
                        <div class="p-6 bg-[#161e31] border-t border-gray-800 flex items-center justify-between">
                            <p class="text-gray-500 text-xs font-medium">Showing <%= pendingContests.length %> contests of <%= (stats.pendingCount + stats.approvedCount + stats.rejectedCount) %></p>
                            <div class="flex gap-2">
                                <button class="px-4 py-1.5 rounded-lg bg-gray-800 text-gray-500 text-xs font-bold border border-gray-700 cursor-not-allowed">Previous</button>
                                <button class="px-4 py-1.5 rounded-lg bg-gray-800 text-gray-300 text-xs font-bold border border-gray-700 hover:bg-gray-700 transition-all">Next</button>
                            </div>
                        </div>
                    </div>
                </div>
            </main>
        </div>
    </div>

    <script>
        // Handle select all functionality
        const selectAll = document.getElementById('selectAll');
        const checkboxes = document.querySelectorAll('.contest-checkbox');

        selectAll.addEventListener('change', (e) => {
            checkboxes.forEach(cb => cb.checked = e.target.checked);
        });

        async function approveContest(id, conflictCount) {
            let msg = 'Are you sure you want to approve this contest schedule?';
            if (conflictCount > 0) {
                msg = '⚠️ WARNING: This contest has ' + conflictCount + ' scheduling conflict(s). Overlapping schedules are detected. Are you sure you want to proceed?';
            }
            if (!confirm(msg)) return;
            
            try {
                const res = await fetch('/college/hod/api/approve-content', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ id, type: 'contest' })
                });
                const data = await res.json();
                if (data.success) {
                    location.reload();
                } else {
                    alert(data.message || 'Error approving contest');
                }
            } catch (err) {
                console.error(err);
                alert('Network error. Please try again.');
            }
        }

        async function bulkApprove() {
            const selectedIds = Array.from(document.querySelectorAll('.contest-checkbox:checked')).map(cb => cb.dataset.id);
            if (selectedIds.length === 0) {
                alert('Please select at least one contest to approve.');
                return;
            }

            if (!confirm(`Are you sure you want to approve ${selectedIds.length} selected contests?`)) return;

            try {
                const res = await fetch('/college/hod/api/bulk-approve-contests', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ ids: selectedIds })
                });
                const data = await res.json();
                if (data.success) {
                    location.reload();
                } else {
                    alert(data.message || 'Error performing bulk approval');
                }
            } catch (err) {
                console.error(err);
                alert('Network error. Please try again.');
            }
        }

        // Delegated Event Listeners for Table Actions
        document.addEventListener('click', (e) => {
            const approveBtn = e.target.closest('.approve-contest-btn');
            const rejectBtn = e.target.closest('.reject-contest-btn');

            if (approveBtn) {
                const id = approveBtn.dataset.id;
                const conflicts = parseInt(approveBtn.dataset.conflicts);
                approveContest(id, conflicts);
            } else if (rejectBtn) {
                const id = rejectBtn.dataset.id;
                rejectContest(id);
            }
        });

        async function rejectContest(id) {
            if (!confirm('Are you sure you want to reject this contest?')) return;
            try {
                const res = await fetch('/college/hod/api/approve-content', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ id, type: 'contest', action: 'reject' })
                });
                const data = await res.json();
                if (data.success) {
                    location.reload();
                } else {
                    alert(data.message || 'Error rejecting contest');
                }
            } catch (err) {
                console.error(err);
                alert('Network error. Please try again.');
            }
        }

        // Handle Filter Form Submission
        const filterForm = document.getElementById('filterForm');
        if (filterForm) {
            filterForm.addEventListener('submit', (e) => {
                // Standard form submission works since it's GET
            });
        }
    </script>
    <!-- PROFILE OVERLAY -->
        <div id="profileOverlay" class="fixed inset-0 z-[80] flex items-center justify-center bg-black/50 backdrop-blur-sm hidden">
        <div class="w-[380px] bg-white dark:bg-gray-800 rounded-3xl shadow-2xl overflow-hidden animate-[fadeIn_0.2s_ease-out]">
            <div class="bg-gradient-to-br from-[#1E4A7A] to-[#153255] relative pt-12 pb-20 px-6 text-center">
                <button id="closeProfileOverlay" class="absolute top-4 right-4 w-8 h-8 rounded-full bg-white/10 hover:bg-white/20 text-white/90 transition-all flex items-center justify-center backdrop-blur-sm">
                    <i class="fas fa-times text-sm"></i>
                </button>

                <div class="absolute left-1/2 bottom-[-48px] -translate-x-1/2">
                    <div class="relative w-24 h-24 rounded-full p-1.5 bg-white dark:bg-gray-800 ring-4 ring-[#1E4A7A]/10 dark:ring-[#1E4A7A]/30">
                        <div class="w-full h-full rounded-full bg-gradient-to-br from-blue-500 to-indigo-600 flex items-center justify-center text-white text-3xl font-bold shadow-inner">
                            <%= user.fullName.split(' ').map(n => n[0]).join('').toUpperCase().slice(0,2) %>
                        </div>
                        <div class="absolute bottom-0 right-0 w-6 h-6 bg-green-500 border-4 border-white dark:border-gray-800 rounded-full"></div>
                    </div>
                </div>
            </div>

            <div class="pt-16 pb-8 px-6">
                <div class="text-center mb-6">
                    <h2 class="text-2xl font-bold text-gray-900 dark:text-white mb-1"><%= user.fullName %></h2>
                    <p class="text-sm font-medium text-gray-500 dark:text-gray-400 mb-3"><%= user.post || 'Faculty Member' %></p>

                    <div class="flex items-center justify-center gap-2 flex-wrap">
                        <span class="px-3 py-1 rounded-full text-xs font-semibold bg-blue-50 text-blue-700 dark:bg-blue-900/30 dark:text-blue-300 border border-blue-100 dark:border-blue-800">
                            <%= user.department || 'General' %> Dept
                        </span>
                        <span class="px-3 py-1 rounded-full text-xs font-semibold bg-purple-50 text-purple-700 dark:bg-purple-900/30 dark:text-purple-300 border border-purple-100 dark:border-purple-800">
                            <%= user.role ? user.role.toUpperCase() : 'FACULTY' %>
                        </span>
                    </div>
                </div>

                <div class="grid grid-cols-2 gap-4 mb-6">
                    <div class="p-3 rounded-2xl bg-gray-50 dark:bg-gray-700/30 border border-gray-100 dark:border-gray-700 text-center">
                        <p class="text-xs text-gray-500 uppercase font-semibold">Faculty ID</p>
                        <p class="text-sm font-bold text-gray-800 dark:text-gray-200">FAC-<%= user.id %></p>
                    </div>
                    <div class="p-3 rounded-2xl bg-gray-50 dark:bg-gray-700/30 border border-gray-100 dark:border-gray-700 text-center">
                        <p class="text-xs text-gray-500 uppercase font-semibold">Joined</p>
                        <p class="text-sm font-bold text-gray-800 dark:text-gray-200"><%= user.joiningDate || 'Unknown' %></p>
                    </div>
                </div>

                <div class="space-y-3">
                    <button id="logoutBtn" class="w-full flex items-center justify-between p-3 rounded-xl hover:bg-red-50 dark:hover:bg-red-900/20 group transition-all duration-200 border border-transparent hover:border-red-100 dark:hover:border-red-800">
                        <div class="flex items-center gap-3">
                            <div class="w-8 h-8 rounded-full bg-red-50 dark:bg-red-900/20 text-red-600 dark:text-red-400 flex items-center justify-center">
                                <i class="fas fa-sign-out-alt text-sm"></i>
                            </div>
                            <span class="text-sm font-medium text-gray-700 dark:text-gray-200 group-hover:text-red-600 dark:group-hover:text-red-400">Logout</span>
                        </div>
                        <i class="fas fa-chevron-right text-xs text-gray-400 group-hover:text-red-500 dark:group-hover:text-red-400"></i>
                    </button>
                </div>
            </div>
        </div>
    </div>

    <script src="/js/hod/index1_logic.js"></script>
</body>

</html>
