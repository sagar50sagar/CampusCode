<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Pending Questions Approval - HOS Dashboard</title>

    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&display=swap"
        rel="stylesheet" />
    <script src="https://cdn.tailwindcss.com"></script>

    <script>
        tailwind.config = {
            darkMode: 'class',
            theme: {
                extend: {
                    fontFamily: { sans: ["Poppins", "sans-serif"] },
                    colors: {
                        primary: { 50: "#E7F0FA", 100: "#D0E1F5", 200: "#7BA4D0", 300: "#4D84C0", 400: "#2E5E99", 500: "#1E4A7A", 600: "#0D2440" },
                        dark: { bg: "#111827", card: "#1F2937", text: "#F9FAFB", border: "#374151" }
                    },
                },
            },
        };
    </script>

    <style>
        /* --- Scrollbar --- */
        ::-webkit-scrollbar { width: 6px; height: 6px; }
        ::-webkit-scrollbar-track { background: transparent; }
        .dark ::-webkit-scrollbar-track { background: #111827; }
        ::-webkit-scrollbar-thumb { background: #7ba4d0; border-radius: 3px; }
        ::-webkit-scrollbar-thumb:hover { background: #2e5e99; }

        /* --- Sidebar Logic --- */
        .sidebar.collapsed { width: 5rem !important; }
        .sidebar.collapsed .nav-item span { display: none !important; }
        .sidebar.collapsed #sidebarLogoText { display: none !important; }
        .sidebar.collapsed nav a, .sidebar.collapsed .p-4 a { justify-content: center !important; padding-left: 0 !important; padding-right: 0 !important; width: 100% !important; }
        .sidebar.collapsed nav a i, .sidebar.collapsed .p-4 a i { margin-right: 0 !important; font-size: 1.25rem !important; }

        /* Animations */
        @keyframes fadeIn { from { opacity: 0; transform: translateY(10px); } to { opacity: 1; transform: translateY(0); } }
        .animate-fadeIn { animation: fadeIn 0.3s ease-out forwards; }
    </style>
    <script src="/js/hos/theme.js"></script>
</head>

<body class="bg-gray-50 dark:bg-gray-900 min-h-screen font-sans transition-colors duration-200">
    <div class="flex h-screen overflow-hidden">
        <!-- Sidebar -->
        <aside id="mainSidebar"
            class="sidebar w-64 bg-white dark:bg-gray-800 shadow-sm border-r border-gray-200 dark:border-gray-700 flex flex-col h-screen flex-shrink-0 transition-all duration-300 z-50">

            <div class="p-6 flex-shrink-0 flex items-center justify-between h-[88px]">
                <h1 class="text-2xl font-bold text-gray-800 dark:text-white flex items-center gap-2 overflow-hidden whitespace-nowrap">
                    <i class="fas fa-code text-primary-500 text-2xl flex-shrink-0"></i>
                    <span id="sidebarLogoText" class="transition-all duration-300 opacity-100">CampusCode</span>
                </h1>
                <button id="sidebarToggleBtn" class="p-1.5 rounded-lg text-gray-400 hover:bg-gray-100 dark:hover:bg-gray-700 hover:text-primary-500 transition-colors focus:outline-none">
                    <i class="fas fa-chevron-left transition-transform duration-300"></i>
                </button>
            </div>

            <nav class="flex-1 space-y-1 overflow-y-auto mt-2 font-sans">
                <a href="/hos/dashboard" class="group flex items-center gap-3 px-6 py-3.5 text-sm font-medium text-gray-600 dark:text-gray-300 hover:bg-gray-50 dark:hover:bg-gray-700 hover:text-gray-900 dark:hover:text-white transition-all border-r-4 border-transparent">
                    <i class="fas fa-home w-5 text-center text-lg"></i>
                    <span class="whitespace-nowrap">Dashboard</span>
                </a>
                <a href="/hos/problem" class="group flex items-center gap-3 px-6 py-3.5 text-sm font-medium bg-primary-50 dark:bg-primary-900/20 text-primary-600 dark:text-primary-400 border-r-4 border-primary-600 dark:border-primary-400 transition-all">
                    <i class="fas fa-tasks w-5 text-center text-lg"></i>
                    <span class="whitespace-nowrap">Problems</span>
                </a>
                <a href="/hos/contest" class="group flex items-center gap-3 px-6 py-3.5 text-sm font-medium text-gray-600 dark:text-gray-300 hover:bg-gray-50 dark:hover:bg-gray-700 hover:text-gray-900 dark:hover:text-white transition-all border-r-4 border-transparent">
                    <i class="fas fa-trophy w-5 text-center text-lg"></i>
                    <span class="whitespace-nowrap">Contests</span>
                </a>
                <a href="/hos/faculty" class="group flex items-center gap-3 px-6 py-3.5 text-sm font-medium text-gray-600 dark:text-gray-300 hover:bg-gray-50 dark:hover:bg-gray-700 hover:text-gray-900 dark:hover:text-white transition-all border-r-4 border-transparent">
                    <i class="fas fa-users w-5 text-center text-lg"></i>
                    <span class="whitespace-nowrap">Faculty</span>
                </a>
                <a href="/hos/student" class="group flex items-center gap-3 px-6 py-3.5 text-sm font-medium text-gray-600 dark:text-gray-300 hover:bg-gray-50 dark:hover:bg-gray-700 hover:text-gray-900 dark:hover:text-white transition-all border-r-4 border-transparent">
                    <i class="fas fa-users w-5 text-center text-lg"></i>
                    <span class="whitespace-nowrap">Students</span>
                </a>
                <a href="/hos/community" class="group flex items-center gap-3 px-6 py-3.5 text-sm font-medium text-gray-600 dark:text-gray-300 hover:bg-gray-50 dark:hover:bg-gray-700 hover:text-gray-900 dark:hover:text-white transition-all border-r-4 border-transparent">
                    <i class="fas fa-comments w-5 text-center text-lg"></i>
                    <span class="whitespace-nowrap">Community</span>
                </a>
                <a href="/hos/report" class="group flex items-center gap-3 px-6 py-3.5 text-sm font-medium text-gray-600 dark:text-gray-300 hover:bg-gray-50 dark:hover:bg-gray-700 hover:text-gray-900 dark:hover:text-white transition-all border-r-4 border-transparent">
                    <i class="fas fa-chart-pie w-5 text-center text-lg"></i>
                    <span class="whitespace-nowrap">Reports</span>
                </a>
            </nav>

            <div class="p-4 space-y-1 border-t border-gray-200 dark:border-gray-700 bg-white dark:bg-gray-800 flex-shrink-0">
                <a href="/hos/help" class="group flex items-center gap-3 px-6 py-3.5 text-sm font-medium text-gray-600 dark:text-gray-300 hover:bg-gray-50 dark:hover:bg-gray-700 hover:text-gray-900 dark:hover:text-white transition-all rounded-lg">
                    <i class="far fa-question-circle w-5 text-center text-lg"></i>
                    <span class="whitespace-nowrap">Help & Support</span>
                </a>
                <a href="/hos/settings" class="group flex items-center gap-3 px-6 py-3.5 text-sm font-medium text-gray-600 dark:text-gray-300 hover:bg-gray-50 dark:hover:bg-gray-700 hover:text-gray-900 dark:hover:text-white transition-all rounded-lg">
                    <i class="fas fa-cog w-5 text-center text-lg group-hover:rotate-90 transition-transform duration-500"></i>
                    <span class="whitespace-nowrap">Settings</span>
                </a>
            </div>
        </aside>

        <!-- Main Content Wrapper -->
        <div class="flex-1 overflow-y-auto flex flex-col">
            <!-- Header -->
            <header class="bg-white dark:bg-gray-800 shadow-sm transition-colors duration-200 sticky top-0 z-40">
                <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-3 flex justify-between items-center">
                    <div class="flex-1 max-w-2xl ml-4 flex items-center gap-4">
                        <h1 id="headerLogoText" class="text-xl font-bold text-gray-800 dark:text-white hidden transition-all duration-300 opacity-0 transform -translate-x-2 whitespace-nowrap">CampusCode</h1>
                        <div class="relative flex items-center w-full">
                            <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
                                <i class="fas fa-search text-gray-400"></i>
                            </div>
                            <input type="text" id="globalSearch" class="block w-full pl-10 pr-3 py-2 rounded-lg border border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-700 text-sm text-gray-900 dark:text-gray-100 placeholder-gray-500 focus:ring-2 focus:ring-primary-400 focus:border-transparent transition-all" placeholder="Search questions..." />
                        </div>
                    </div>

                    <div class="ml-4 flex items-center gap-3">
                        <button id="themeToggleBtn" class="p-2 rounded-full text-gray-500 hover:text-gray-700 dark:text-gray-400 dark:hover:text-gray-200 focus:outline-none transition-transform active:scale-95">
                            <i class="fas fa-moon text-xl"></i>
                        </button>
                        <div class="relative">
                            <button id="notificationBtn" class="p-2 rounded-full text-gray-500 dark:text-gray-400 hover:text-gray-700 dark:hover:text-gray-200 focus:outline-none">
                                <i class="fas fa-bell text-xl"></i>
                                <span class="absolute top-0 right-0 h-2 w-2 rounded-full bg-red-50 border-2 border-white dark:border-gray-800"></span>
                            </button>
                        </div>
                        <button id="headerProfileBtn" class="ml-2 flex items-center gap-3 p-1 pr-3 rounded-full hover:bg-gray-100 dark:hover:bg-gray-700 transition-colors">
                            <div class="h-9 w-9 rounded-full bg-primary-500 flex items-center justify-center text-white font-bold text-sm">
                                <%= user.fullName.split(' ').map(n => n[0]).join('') %>
                            </div>
                            <span class="text-sm font-medium text-gray-700 dark:text-gray-200 hidden sm:block"><%= user.fullName %></span>
                        </button>
                    </div>
                </div>
            </header>

            <!-- Main Scrollable Area -->
            <main class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-6 w-full">
                <!-- Title Section -->
                <div class="mb-6 flex flex-col md:flex-row md:items-center justify-between gap-4">
                    <div>
                        <h1 class="text-2xl font-bold text-gray-800 dark:text-white flex items-center gap-2">
                            <i class="fas fa-clipboard-check text-orange-500"></i>
                            Pending Questions Approval
                        </h1>
                        <p class="text-gray-600 dark:text-gray-400 mt-1">Review and approve questions submitted by faculty members</p>
                    </div>
                    <div class="flex flex-wrap gap-2">
                        <a href="/hos/problem" class="px-4 py-2 bg-gray-500 hover:bg-gray-600 text-white rounded-lg text-sm font-medium transition-colors shadow-sm flex items-center gap-2">
                            <i class="fas fa-arrow-left"></i> Back
                        </a>
                        <button id="btnBulkApprove" class="px-4 py-2 bg-green-500 hover:bg-green-600 text-white rounded-lg text-sm font-medium transition-colors shadow-sm flex items-center gap-2 opacity-50 cursor-not-allowed" disabled>
                            <i class="fas fa-check-double"></i> Bulk Approve
                        </button>
                        <button id="btnBulkReject" class="px-4 py-2 bg-red-500 hover:bg-red-600 text-white rounded-lg text-sm font-medium transition-colors shadow-sm flex items-center gap-2 opacity-50 cursor-not-allowed" disabled>
                            <i class="fas fa-times-circle"></i> Bulk Reject
                        </button>
                        <button id="btnExportData" class="px-4 py-2 bg-primary-500 hover:bg-primary-600 text-white rounded-lg text-sm font-medium transition-colors shadow-sm flex items-center gap-2">
                            <i class="fas fa-download"></i> Export
                        </button>
                    </div>
                </div>

                <!-- Stats Cards -->
                <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4 mb-6">
                    <div class="bg-white dark:bg-gray-800 rounded-xl shadow-sm p-4 border border-gray-100 dark:border-gray-700 flex items-center justify-between">
                        <div>
                            <p class="text-xs font-medium text-gray-500 dark:text-gray-400 uppercase">Total Pending</p>
                            <h3 class="text-2xl font-bold text-gray-900 dark:text-white mt-1" id="statTotal"><%= questionStats.total %></h3>
                        </div>
                        <div class="p-3 bg-orange-500/10 rounded-lg"><i class="fas fa-clock text-orange-500 text-xl"></i></div>
                    </div>
                    <div class="bg-white dark:bg-gray-800 rounded-xl shadow-sm p-4 border border-gray-100 dark:border-gray-700 flex items-center justify-between">
                        <div>
                            <p class="text-xs font-medium text-gray-500 dark:text-gray-400 uppercase">Approved</p>
                            <h3 class="text-2xl font-bold text-gray-900 dark:text-white mt-1" id="statApproved"><%= questionStats.approved %></h3>
                        </div>
                        <div class="p-3 bg-green-500/10 rounded-lg"><i class="fas fa-check-circle text-green-500 text-xl"></i></div>
                    </div>
                    <div class="bg-white dark:bg-gray-800 rounded-xl shadow-sm p-4 border border-gray-100 dark:border-gray-700 flex items-center justify-between">
                        <div>
                            <p class="text-xs font-medium text-gray-500 dark:text-gray-400 uppercase">Rejected</p>
                            <h3 class="text-2xl font-bold text-gray-900 dark:text-white mt-1" id="statRejected"><%= questionStats.rejected %></h3>
                        </div>
                        <div class="p-3 bg-red-500/10 rounded-lg"><i class="fas fa-times-circle text-red-500 text-xl"></i></div>
                    </div>
                    <div class="bg-white dark:bg-gray-800 rounded-xl shadow-sm p-4 border border-gray-100 dark:border-gray-700 flex items-center justify-between">
                        <div>
                            <p class="text-xs font-medium text-gray-500 dark:text-gray-400 uppercase">This Week</p>
                            <h3 class="text-2xl font-bold text-gray-900 dark:text-white mt-1" id="statWeek"><%= questionStats.thisWeek %></h3>
                        </div>
                        <div class="p-3 bg-blue-500/10 rounded-lg"><i class="fas fa-calendar-week text-blue-500 text-xl"></i></div>
                    </div>
                </div>

                <!-- Table Container -->
                <div class="bg-white dark:bg-gray-800 rounded-xl shadow-sm border border-gray-200 dark:border-gray-700 overflow-hidden">
                    <!-- Tabs -->
                    <div class="flex border-b border-gray-200 dark:border-gray-700 overflow-x-auto">
                        <button class="approval-tab active px-6 py-4 text-sm font-medium text-primary-600 dark:text-primary-400 border-b-2 border-primary-500 focus:outline-none whitespace-nowrap" data-tab="pending">
                            Pending <span class="ml-2 px-2 py-0.5 rounded-full bg-primary-100 dark:bg-primary-900/30 text-xs"><%= questionStats.total %></span>
                        </button>
                        <button class="approval-tab px-6 py-4 text-sm font-medium text-gray-500 dark:text-gray-400 hover:text-gray-700 dark:hover:text-gray-200 focus:outline-none whitespace-nowrap" data-tab="approved">
                            Approved <span class="ml-2 px-2 py-0.5 rounded-full bg-gray-100 dark:bg-gray-700 text-xs"><%= questionStats.approved %></span>
                        </button>
                        <button class="approval-tab px-6 py-4 text-sm font-medium text-gray-500 dark:text-gray-400 hover:text-gray-700 dark:hover:text-gray-200 focus:outline-none whitespace-nowrap" data-tab="rejected">
                            Rejected <span class="ml-2 px-2 py-0.5 rounded-full bg-gray-100 dark:bg-gray-700 text-xs"><%= questionStats.rejected %></span>
                        </button>
                    </div>

                    <!-- Filters -->
                    <div class="p-4 bg-gray-50 dark:bg-gray-800/30 border-b border-gray-200 dark:border-gray-700">
                        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4">
                            <div>
                                <label class="block text-xs font-medium text-gray-700 dark:text-gray-300 mb-1 uppercase tracking-wider">Subject</label>
                                <select id="filterSubject" class="w-full text-sm border-gray-300 dark:border-gray-600 rounded-lg px-3 py-2 bg-white dark:bg-gray-700 text-gray-900 dark:text-white">
                                    <option value="">All Subjects</option>
                                    <% subjects.forEach(s => { %><option value="<%= s %>"><%= s %></option><% }) %>
                                </select>
                            </div>
                            <div>
                                <label class="block text-xs font-medium text-gray-700 dark:text-gray-300 mb-1 uppercase tracking-wider">Date From</label>
                                <input type="date" id="filterDateFrom" class="w-full text-sm border-gray-300 dark:border-gray-600 rounded-lg px-3 py-2 bg-white dark:bg-gray-700 text-gray-900 dark:text-white">
                            </div>
                            <div>
                                <label class="block text-xs font-medium text-gray-700 dark:text-gray-300 mb-1 uppercase tracking-wider">Date To</label>
                                <input type="date" id="filterDateTo" class="w-full text-sm border-gray-300 dark:border-gray-600 rounded-lg px-3 py-2 bg-white dark:bg-gray-700 text-gray-900 dark:text-white">
                            </div>
                            <div class="flex items-end gap-2">
                                <button id="btnApplyFilters" class="flex-1 py-2 bg-primary-500 hover:bg-primary-600 text-white rounded-lg text-sm font-medium transition-colors">Apply</button>
                                <button id="btnResetFilters" class="px-3 py-2 bg-gray-200 dark:bg-gray-700 text-gray-700 dark:text-gray-300 rounded-lg text-sm transition-colors"><i class="fas fa-redo"></i></button>
                            </div>
                        </div>
                    </div>

                    <!-- Table -->
                    <div class="overflow-x-auto">
                        <table class="w-full text-left border-collapse">
                            <thead>
                                <tr class="text-xs font-semibold text-gray-500 dark:text-gray-400 bg-gray-50 dark:bg-gray-700/50 uppercase tracking-wider">
                                    <th class="px-4 py-3 w-10"><input type="checkbox" id="selectAll" class="rounded border-gray-300 text-primary-600"></th>
                                    <th class="px-4 py-3">Title</th>
                                    <th class="px-4 py-3">Difficulty</th>
                                    <th class="px-4 py-3">Faculty</th>
                                    <th class="px-4 py-3">Subject</th>
                                    <th class="px-4 py-3 text-center">Actions</th>
                                </tr>
                            </thead>
                            <tbody id="questionsTableBody" class="divide-y divide-gray-200 dark:divide-gray-700 text-sm">
                                <!-- Data injected by JS -->
                            </tbody>
                        </table>
                    </div>

                    <!-- Pagination -->
                    <div class="px-4 py-4 border-t border-gray-200 dark:border-gray-700 flex items-center justify-between">
                        <span class="text-xs text-gray-500">Page <span id="currentPage">1</span> of <span id="totalPages">1</span> (<span id="displayCount">0</span> items)</span>
                        <div class="flex gap-2">
                            <button id="btnPrevPage" class="px-3 py-1 bg-gray-100 dark:bg-gray-700 rounded text-xs disabled:opacity-50">Prev</button>
                            <button id="btnNextPage" class="px-3 py-1 bg-gray-100 dark:bg-gray-700 rounded text-xs disabled:opacity-50">Next</button>
                        </div>
                    </div>
                </div>
            </main>
        </div>
    </div>

    <!-- Modals -->
    <div id="questionDetailModal" class="fixed inset-0 z-50 flex items-center justify-center bg-black/50 backdrop-blur-sm hidden">
        <div class="w-full max-w-4xl bg-white dark:bg-gray-800 rounded-3xl shadow-2xl overflow-hidden animate-fadeIn m-4 max-h-[90vh] overflow-y-auto">
            <div class="bg-gradient-to-br from-primary-500 to-primary-700 relative px-6 py-4 flex justify-between items-center">
                <h2 class="text-xl font-bold text-white">Question Details</h2>
                <button id="closeQuestionModal" class="w-8 h-8 rounded-full bg-white/10 hover:bg-white/20 text-white flex items-center justify-center backdrop-blur-sm"><i class="fas fa-times"></i></button>
            </div>
            <div class="p-6" id="questionDetailContent"></div>
        </div>
    </div>

    <!-- Notification Dropdown -->
    <div id="notificationDropdown" class="fixed top-16 right-6 z-[70] w-80 bg-white dark:bg-gray-800 rounded-xl shadow-xl border border-gray-100 dark:border-gray-700 hidden">
        <div class="p-4 border-b border-gray-100 dark:border-gray-700 flex justify-between items-center">
            <h3 class="font-semibold text-gray-800 dark:text-white">Notifications</h3>
            <span class="text-xs text-primary-500 cursor-pointer hover:underline">Mark all read</span>
        </div>
        <div class="p-2">
            <div class="p-3 hover:bg-gray-50 dark:hover:bg-gray-700 rounded-lg cursor-pointer">
                <p class="text-sm text-gray-800 dark:text-gray-200 font-medium">New Submission</p>
                <p class="text-xs text-gray-500">Pending review.</p>
            </div>
        </div>
    </div>

    <!-- Profile Overlay -->
    <div id="profileOverlay" class="fixed inset-0 z-[80] flex items-center justify-center bg-black/50 backdrop-blur-sm hidden">
        <div class="w-[380px] bg-white dark:bg-gray-800 rounded-3xl shadow-2xl overflow-hidden animate-fadeIn">
            <div class="bg-gradient-to-br from-[#1E4A7A] to-[#153255] relative pt-12 pb-20 px-6 text-center">
                <button id="closeProfileOverlay" class="absolute top-4 right-4 w-8 h-8 rounded-full bg-white/10 hover:bg-white/20 text-white flex items-center justify-center"><i class="fas fa-times"></i></button>
                <div class="absolute left-1/2 bottom-[-48px] -translate-x-1/2">
                    <div class="w-24 h-24 rounded-full p-1.5 bg-white dark:bg-gray-800 ring-4 ring-[#1E4A7A]/10">
                        <div class="w-full h-full rounded-full bg-gradient-to-br from-blue-500 to-indigo-600 flex items-center justify-center text-white text-3xl font-bold">
                            <%= user.fullName.split(' ').map(n => n[0]).join('').toUpperCase().slice(0,2) %>
                        </div>
                    </div>
                </div>
            </div>
            <div class="pt-16 pb-8 px-6 text-center">
                <h2 class="text-2xl font-bold text-gray-900 dark:text-white"><%= user.fullName %></h2>
                <p class="text-sm text-gray-500 mb-4 uppercase tracking-widest"><%= user.post || 'HOS' %></p>
                <button onclick="window.location.href='/auth/logout'" class="w-full py-3 bg-red-50 dark:bg-red-900/20 text-red-600 dark:text-red-400 rounded-xl font-bold flex items-center justify-center gap-2 hover:bg-red-100 transition-all"><i class="fas fa-sign-out-alt"></i> Logout</button>
            </div>
        </div>
    </div>

    <!-- Toast -->
    <div id="toastNotification" class="fixed top-20 right-6 z-[90] hidden animate-fadeIn">
        <div id="toastContent" class="bg-white dark:bg-gray-800 rounded-xl shadow-2xl border border-gray-100 dark:border-gray-700 p-4 min-w-[320px] flex items-start gap-3">
            <div id="toastIcon" class="w-8 h-8 rounded-full flex items-center justify-center text-white"></div>
            <div class="flex-1">
                <h4 id="toastTitle" class="font-bold text-sm"></h4>
                <p id="toastMessage" class="text-xs text-gray-500"></p>
            </div>
        </div>
    </div>

    <!-- Confirm -->
    <div id="confirmDialog" class="fixed inset-0 z-[100] flex items-center justify-center bg-black/50 hidden">
        <div class="bg-white dark:bg-gray-800 rounded-2xl p-6 max-w-sm w-full m-4 shadow-2xl animate-fadeIn">
            <h3 id="confirmTitle" class="text-lg font-bold mb-2 text-gray-900 dark:text-white">Confirm Action</h3>
            <p id="confirmMessage" class="text-sm text-gray-500 mb-6"></p>
            <div class="flex gap-2 justify-end">
                <button id="confirmCancelBtn" class="px-4 py-2 bg-gray-100 dark:bg-gray-700 rounded-lg text-sm">Cancel</button>
                <button id="confirmOkBtn" class="px-4 py-2 bg-primary-500 text-white rounded-lg text-sm">Confirm</button>
            </div>
        </div>
    </div>

    <script>
        let allQuestions = <%- JSON.stringify(questions) %>;
        let currentTab = 'pending';
        let currentPage = 1;
        const itemsPerPage = 8;

        // theme.js handles all theme logic (loaded in <head>)

        // Sidebar
        const sidebar = document.getElementById('mainSidebar');
        document.getElementById('sidebarToggleBtn').onclick = () => {
            sidebar.classList.toggle('collapsed');
            const icon = document.getElementById('sidebarToggleBtn').querySelector('i');
            icon.style.transform = sidebar.classList.contains('collapsed') ? 'rotate(180deg)' : 'rotate(0deg)';
        };

        // Table
        const render = () => {
            let data = allQuestions.filter(q => {
                if(currentTab === 'approved') return q.status === 'accepted';
                if(currentTab === 'rejected') return q.status === 'rejected';
                return q.status === 'pending';
            });

            const sub = document.getElementById('filterSubject').value;
            const from = document.getElementById('filterDateFrom').value;
            const to = document.getElementById('filterDateTo').value;
            if(sub) data = data.filter(q => q.subject === sub);
            if(from) data = data.filter(q => q.createdAt >= from);
            if(to) data = data.filter(q => q.createdAt <= to);

            const pages = Math.ceil(data.length / itemsPerPage) || 1;
            const slice = data.slice((currentPage-1)*itemsPerPage, currentPage*itemsPerPage);

            document.getElementById('displayCount').innerText = data.length;
            document.getElementById('totalPages').innerText = pages;
            document.getElementById('currentPage').innerText = currentPage;
            document.getElementById('btnPrevPage').disabled = currentPage === 1;
            document.getElementById('btnNextPage').disabled = currentPage === pages;

            const body = document.getElementById('questionsTableBody');
            if(!slice.length) {
                body.innerHTML = `<tr><td colspan="6" class="text-center py-20 text-gray-400">No questions found</td></tr>`;
                return;
            }

            body.innerHTML = slice.map(q => `
                <tr class="hover:bg-gray-50 dark:hover:bg-gray-700/30 transition-colors">
                    <td class="px-4 py-3">${q.status === 'pending' ? '<input type="checkbox" class="row-checkbox rounded" data-id="' + q.id + '">' : ''}</td>
                    <td class="px-4 py-3 font-medium">${q.title}</td>
                    <td class="px-4 py-3"><span class="px-2 py-0.5 rounded-full text-xs ${q.difficulty === 'Easy' ? 'bg-green-100 text-green-700' : q.difficulty === 'Hard' ? 'bg-red-100 text-red-700' : 'bg-yellow-100 text-yellow-700'}">${q.difficulty}</span></td>
                    <td class="px-4 py-3">${q.faculty}</td>
                    <td class="px-4 py-3 text-gray-500">${q.subject}</td>
                    <td class="px-4 py-3 text-center">
                        <div class="flex items-center justify-center gap-1">
                            <button onclick="showDetails(${q.id})" class="p-1.5 text-blue-500 hover:bg-blue-100 dark:hover:bg-blue-900/30 rounded" title="View Details"><i class="fas fa-eye"></i></button>
                            ${q.status === 'pending' ? `
                                <button onclick="verifyOne(${q.id}, 'approve')" class="p-1.5 text-green-500 hover:bg-green-100 dark:hover:bg-green-900/30 rounded" title="Approve"><i class="fas fa-check"></i></button>
                                <button onclick="verifyOne(${q.id}, 'reject')" class="p-1.5 text-red-500 hover:bg-red-100 dark:hover:bg-red-900/30 rounded" title="Reject"><i class="fas fa-times"></i></button>
                            ` : `<span class="px-2 py-0.5 ml-1 text-[10px] font-bold uppercase rounded ${q.status === 'accepted' || q.status === 'approved' ? 'text-green-600 bg-green-50' : 'text-red-600 bg-red-50'}">${q.status}</span>`}
                        </div>
                    </td>
                </tr>
            `).join('');
            updateBulk();
        };

        const updateBulk = () => {
            const count = document.querySelectorAll('.row-checkbox:checked').length;
            ['btnBulkApprove', 'btnBulkReject'].forEach(id => {
                const btn = document.getElementById(id);
                btn.disabled = !count;
                btn.classList.toggle('opacity-50', !count);
                btn.classList.toggle('cursor-not-allowed', !count);
            });
        };

        document.getElementById('selectAll').onchange = (e) => {
            document.querySelectorAll('.row-checkbox').forEach(cb => cb.checked = e.target.checked);
            updateBulk();
        };
        document.getElementById('questionsTableBody').onclick = (e) => { if(e.target.classList.contains('row-checkbox')) updateBulk(); };

        document.querySelectorAll('.approval-tab').forEach(btn => btn.onclick = () => {
            document.querySelectorAll('.approval-tab').forEach(b => b.classList.remove('active', 'text-primary-600', 'border-b-2', 'border-primary-500'));
            btn.classList.add('active', 'text-primary-600', 'border-b-2', 'border-primary-500');
            currentTab = btn.dataset.tab;
            currentPage = 1;
            render();
        });

        document.getElementById('btnApplyFilters').onclick = render;
        document.getElementById('btnResetFilters').onclick = () => {
            document.querySelectorAll('#filterSubject, #filterDateFrom, #filterDateTo').forEach(i => i.value = '');
            render();
        };

        const performAction = async (ids, action) => {
            const resp = await fetch('/hos/bulk-verify', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ questionIds: ids, action })
            });
            const res = await resp.json();
            if(res.success) {
                toast(res.message, 'success', 'Done');
                allQuestions.forEach(q => {
                    if (ids.includes(q.id)) {
                        q.status = action === 'approve' ? 'accepted' : 'rejected';
                    }
                });
                
                // Also optionally update the stats visually immediately or let a refresh handle it
                const stApproved = document.getElementById('statApproved');
                const stRejected = document.getElementById('statRejected');
                const stTotal = document.getElementById('statTotal');
                const tabApproved = document.querySelector('button[data-tab="approved"] span');
                const tabRejected = document.querySelector('button[data-tab="rejected"] span');
                // Decrement total
                if (stTotal && !isNaN(parseInt(stTotal.innerText))) {
                   stTotal.innerText = parseInt(stTotal.innerText) - ids.length;
                }
                
                if (action === 'approve') {
                    if (stApproved) stApproved.innerText = parseInt(stApproved.innerText || 0) + ids.length;
                    if (tabApproved) tabApproved.innerText = parseInt(tabApproved.innerText || 0) + ids.length;
                } else {
                    if (stRejected) stRejected.innerText = parseInt(stRejected.innerText || 0) + ids.length;
                    if (tabRejected) tabRejected.innerText = parseInt(tabRejected.innerText || 0) + ids.length;
                }
                
                render();
            } else toast(res.error, 'error', 'Failed');
        };

        const verifyOne = async (id, action) => {
            if(await confirm(`Are you sure you want to ${action}?`)) performAction([id], action);
        };
        document.getElementById('btnBulkApprove').onclick = () => {
            const ids = Array.from(document.querySelectorAll('.row-checkbox:checked')).map(cb => parseInt(cb.dataset.id));
            verifyOne(null, 'approve').then(ok => { if(ok) performAction(ids, 'approve'); }); // Reuse confirm logic
        };

        // Redefine verifyOne to handle the prompt better
        const showDetails = (id) => {
            const q = allQuestions.find(it => it.id === id);
            document.getElementById('questionDetailContent').innerHTML = `
                <div class="space-y-4">
                    <h3 class="text-xl font-bold">${q.title}</h3>
                    <div class="p-4 bg-gray-50 dark:bg-gray-700/50 rounded-xl text-sm">${q.description}</div>
                    <div class="grid grid-cols-2 gap-4 text-xs font-mono">
                        <div class="p-3 bg-black text-green-400 rounded">Input:<br>${q.sample_input}</div>
                        <div class="p-3 bg-black text-green-400 rounded">Output:<br>${q.sample_output}</div>
                    </div>
                </div>
            `;
            document.getElementById('questionDetailModal').classList.remove('hidden');
        };
        document.getElementById('closeQuestionModal').onclick = () => document.getElementById('questionDetailModal').classList.add('hidden');

        // Helpers
        const toast = (m, t, title) => {
            const el = document.getElementById('toastNotification');
            document.getElementById('toastTitle').innerText = title;
            document.getElementById('toastMessage').innerText = m;
            document.getElementById('toastIcon').className = `w-8 h-8 rounded-full flex items-center justify-center ${t === 'success' ? 'bg-green-500' : 'bg-red-500'}`;
            document.getElementById('toastIcon').innerHTML = `<i class="fas fa-${t === 'success' ? 'check' : 'times'}"></i>`;
            el.classList.remove('hidden');
            setTimeout(() => el.classList.add('hidden'), 3000);
        };

        let confirmRes;
        const confirm = (m) => {
            document.getElementById('confirmMessage').innerText = m;
            document.getElementById('confirmDialog').classList.remove('hidden');
            return new Promise(res => confirmRes = res);
        };
        document.getElementById('confirmOkBtn').onclick = () => { document.getElementById('confirmDialog').classList.add('hidden'); confirmRes(true); };
        document.getElementById('confirmCancelBtn').onclick = () => { document.getElementById('confirmDialog').classList.add('hidden'); confirmRes(false); };

        document.getElementById('headerProfileBtn').onclick = () => document.getElementById('profileOverlay').classList.remove('hidden');
        document.getElementById('closeProfileOverlay').onclick = () => document.getElementById('profileOverlay').classList.add('hidden');

        render();
    </script>
</body>
</html>