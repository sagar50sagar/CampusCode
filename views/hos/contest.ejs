            <div class="p-5 border-t border-gray-100 dark:border-gray-700 bg-gray-50 dark:bg-gray-800/50 flex justify-end gap-3 shrink-0">
                <button id="btn-modal-close"
                    class="px-5 py-2.5 rounded-xl text-sm font-medium text-gray-600 dark:text-gray-300 hover:bg-white dark:hover:bg-gray-700 hover:shadow-sm transition-all border border-transparent hover:border-gray-200 dark:hover:border-gray-600">
                    Close Preview
                </button>

                <button id="btn-modal-edit"
                    class="px-5 py-2.5 rounded-xl text-sm font-medium bg-primary-600 text-white hover:bg-primary-700 shadow-lg shadow-primary-500/30 transition-all flex items-center gap-2">
                    <i class="fas fa-pen text-xs"></i> Edit Details
                </button>
            </div>
        </div>
    </div>


    <!-- Manage Problems Modal -->
    <div id="addProblemModal" class="fixed inset-0 z-[120] hidden flex items-center justify-center bg-black/60 backdrop-blur-md p-4">
        <div class="bg-white dark:bg-gray-800 w-full max-w-4xl rounded-[2.5rem] shadow-2xl p-8 max-h-[90vh] flex flex-col animate-fadeIn">
            <div class="flex justify-between items-center mb-6 shrink-0">
                <h3 class="text-2xl font-bold dark:text-white flex items-center gap-3">
                    <i class="fas fa-tasks text-primary-500"></i> Manage Contest Problems
                </h3>
                <button id="closeAddProblemModal" class="h-10 w-10 rounded-full hover:bg-gray-200 dark:hover:bg-gray-700 flex items-center justify-center transition-colors">
                    <i class="fas fa-times text-gray-500 dark:text-gray-300"></i>
                </button>
            </div>
            
            <div class="mb-4 relative shrink-0">
                <i class="fas fa-search absolute left-4 top-1/2 -translate-y-1/2 text-gray-400"></i>
                <input type="text" id="problemSearch" placeholder="Search problems by title, subject, or difficulty..." 
                    class="w-full pl-11 pr-4 py-3 rounded-xl border border-gray-100 dark:border-gray-700 bg-gray-50 dark:bg-gray-900 text-sm dark:text-white outline-none focus:ring-2 focus:ring-primary-500 transition-all">
            </div>

            <div class="bg-white dark:bg-gray-800 rounded-2xl border border-gray-100 dark:border-gray-700 overflow-hidden flex-1 flex flex-col min-h-[300px]">
                <div class="overflow-y-auto flex-1 custom-scrollbar">
                    <table class="w-full text-left relative border-collapse">
                        <thead class="bg-gray-50 dark:bg-gray-900/50 text-[10px] uppercase font-bold text-gray-400 tracking-widest sticky top-0 z-10 border-b border-gray-100 dark:border-gray-700">
                            <tr>
                                <th class="px-6 py-4 w-12 text-center">
                                    <input type="checkbox" id="selectAllProblems" class="rounded border-gray-300 text-primary-600 cursor-pointer focus:ring-0">
                                </th>
                                <th class="px-6 py-4">Title & Subject</th>
                                <th class="px-6 py-4 text-center">Difficulty</th>
                                <th class="px-6 py-4 text-center">Created By</th>
                                <th class="px-6 py-4 text-center">Action</th>

                            </tr>
                        </thead>
                        <tbody id="available-problems-list" class="divide-y divide-gray-50 dark:divide-gray-700/50">
                            <!-- Populated via JS -->
                        </tbody>
                    </table>
                </div>
            </div>

            <div class="flex gap-4 pt-6 mt-4 border-t dark:border-gray-700 shrink-0 items-center justify-between">
                <div class="flex items-center text-sm font-bold text-gray-600 dark:text-gray-300">
                    <span id="selectedProblemsCount" class="bg-primary-100 dark:bg-primary-900/30 text-primary-600 dark:text-primary-400 px-3 py-1 rounded-lg mr-2 font-mono">0</span> problems selected
                </div>
                <button id="btn-save-assigned-problems" class="bg-primary-600 text-white px-8 py-3 rounded-xl font-bold hover:bg-primary-700 shadow-lg shadow-primary-500/20 transition-all active:scale-95">
                    Apply Selection
                </button>
            </div>
        </div>
    </div>

    <!-- Problem Details Modal -->
    <div id="problemDetailsModal" class="fixed inset-0 z-[150] hidden flex items-center justify-center bg-black/60 backdrop-blur-md p-4">
        <div class="bg-white dark:bg-gray-800 w-full max-w-2xl rounded-3xl shadow-2xl p-8 max-h-[85vh] overflow-y-auto animate-fadeIn relative custom-scrollbar">
            <button onclick="document.getElementById('problemDetailsModal').classList.add('hidden')" class="absolute top-6 right-6 h-10 w-10 rounded-full hover:bg-gray-100 dark:hover:bg-gray-700 flex items-center justify-center transition-colors">
                <i class="fas fa-times text-gray-500 dark:text-gray-300"></i>
            </button>
            <div id="problem-details-content">
                <!-- Content injected via JS -->
            </div>
        </div>
    </div>


    <div id="settingsMenu"
        class="hidden fixed bottom-16 left-4 w-72 bg-white dark:bg-gray-800 border border-gray-100 dark:border-gray-700 shadow-2xl rounded-2xl z-[9999] overflow-hidden transform transition-all duration-200 origin-bottom-left">
        <div class="p-2 space-y-1">
            <div class="px-3 py-2 text-xs font-semibold text-gray-400 uppercase tracking-wider">Account</div>
            <a href="profile.html"
                class="flex items-center gap-3 px-3 py-2 text-sm font-medium text-gray-700 dark:text-gray-200 hover:bg-gray-50 dark:hover:bg-gray-700 rounded-xl transition-colors cursor-pointer group">
                <i class="fas fa-user-circle w-5 text-gray-400 group-hover:text-primary-500 transition-colors"></i>
                Profile
            </a>
        </div>
        <div class="h-px bg-gray-100 dark:bg-gray-700 mx-4"></div>
        <div class="p-2 space-y-1">
            <div class="px-3 py-2 text-xs font-semibold text-gray-400 uppercase tracking-wider">Preferences</div>
            <button id="themeAccordionBtn"
                class="w-full flex justify-between items-center px-3 py-2 text-sm font-medium text-gray-700 dark:text-gray-200 hover:bg-gray-50 dark:hover:bg-gray-700 rounded-xl transition-colors cursor-pointer group focus:outline-none">
                <div class="flex items-center gap-3">
                    <i class="fas fa-palette w-5 text-gray-400 group-hover:text-primary-500 transition-colors"></i>
                    <span>Theme</span>
                </div>
                <i id="themeChevron"
                    class="fas fa-chevron-right text-xs text-gray-400 transition-transform duration-200"></i>
            </button>
            <div id="themeOptionsContainer" class="hidden pl-4 pr-1 space-y-1 pb-1">
                <button data-value="light"
                    class="theme-option w-full flex items-center justify-between px-3 py-2 rounded-lg text-sm text-gray-600 dark:text-gray-400 hover:bg-gray-100 dark:hover:bg-gray-700/50 transition-colors">
                    <span class="flex items-center gap-2"><i class="fas fa-sun text-orange-400 w-4"></i> Light</span>
                    <i class="fas fa-check text-primary-500 opacity-0 check-icon"></i>
                </button>
                <button data-value="dark"
                    class="theme-option w-full flex items-center justify-between px-3 py-2 rounded-lg text-sm text-gray-600 dark:text-gray-400 hover:bg-gray-100 dark:hover:bg-gray-700/50 transition-colors">
                    <span class="flex items-center gap-2"><i class="fas fa-moon text-indigo-400 w-4"></i> Dark</span>
                    <i class="fas fa-check text-primary-500 opacity-0 check-icon"></i>
                </button>
                <button data-value="system"
                    class="theme-option w-full flex items-center justify-between px-3 py-2 rounded-lg text-sm text-gray-600 dark:text-gray-400 hover:bg-gray-100 dark:hover:bg-gray-700/50 transition-colors">
                    <span class="flex items-center gap-2"><i class="fas fa-desktop text-gray-400 w-4"></i> System</span>
                    <i class="fas fa-check text-primary-500 opacity-0 check-icon"></i>
                </button>
            </div>
        </div>
    </div>

    <script>
        document.addEventListener("DOMContentLoaded", function () {

            /* =========================================================================
               1. NAVIGATION & SIDEBAR
               ========================================================================= */
            const sidebar = document.getElementById('mainSidebar');
            const toggleBtn = document.getElementById('sidebarToggleBtn');
            const sidebarLogoText = document.getElementById('sidebarLogoText');
            const headerLogoText = document.getElementById('headerLogoText');
            const toggleIcon = toggleBtn ? toggleBtn.querySelector('i') : null;

            if (toggleBtn && sidebar) {
                toggleBtn.addEventListener('click', () => {
                    sidebar.classList.toggle('collapsed');

                    if (sidebar.classList.contains('collapsed')) {
                        sidebar.classList.replace('w-64', 'w-20');
                        if (toggleIcon) toggleIcon.style.transform = 'rotate(180deg)';
                        if (sidebarLogoText) {
                            sidebarLogoText.style.opacity = '0';
                            setTimeout(() => sidebarLogoText.style.display = 'none', 100);
                        }
                        if (headerLogoText) {
                            headerLogoText.classList.remove('hidden');
                            setTimeout(() => headerLogoText.classList.remove('opacity-0', '-translate-x-2'), 50);
                        }
                    } else {
                        sidebar.classList.replace('w-20', 'w-64');
                        if (toggleIcon) toggleIcon.style.transform = 'rotate(0deg)';
                        if (sidebarLogoText) {
                            sidebarLogoText.style.display = 'inline';
                            setTimeout(() => sidebarLogoText.style.opacity = '1', 50);
                        }
                        if (headerLogoText) {
                            headerLogoText.classList.add('opacity-0', '-translate-x-2');
                            setTimeout(() => headerLogoText.classList.add('hidden'), 300);
                        }
                    }
                });
            }

            /* =========================================================================
               2. THEME TOGGLE (Main & Settings Menu)
               ========================================================================= */
            const themeBtn = document.getElementById('themeToggleBtn');
            const html = document.documentElement;
            const themeIcon = themeBtn ? themeBtn.querySelector('i') : null;

            // Function to set theme
            function setTheme(theme) {
                if (theme === 'dark') {
                    html.classList.add('dark');
                    localStorage.theme = 'dark';
                    if (themeIcon) themeIcon.classList.replace('fa-moon', 'fa-sun');
                } else {
                    html.classList.remove('dark');
                    localStorage.theme = 'light';
                    if (themeIcon) themeIcon.classList.replace('fa-sun', 'fa-moon');
                }
            }

            // Init Check
            if (localStorage.theme === 'dark' || (!('theme' in localStorage) && window.matchMedia('(prefers-color-scheme: dark)').matches)) {
                setTheme('dark');
            } else {
                setTheme('light');
            }

            // Topbar Toggle
            if (themeBtn) {
                themeBtn.addEventListener('click', () => {
                    const isDark = html.classList.contains('dark');
                    setTheme(isDark ? 'light' : 'dark');
                });
            }

            // Settings Menu Theme Options
            const themeOptions = document.querySelectorAll('.theme-option');
            themeOptions.forEach(option => {
                option.addEventListener('click', () => {
                    const val = option.getAttribute('data-value');
                    if (val === 'system') {
                        localStorage.removeItem('theme');
                        if (window.matchMedia('(prefers-color-scheme: dark)').matches) setTheme('dark');
                        else setTheme('light');
                    } else {
                        setTheme(val);
                    }

                    // Update Check Icons
                    document.querySelectorAll('.check-icon').forEach(icon => icon.classList.add('opacity-0'));
                    option.querySelector('.check-icon').classList.remove('opacity-0');
                });
            });


            /* =========================================================================
               3. OVERLAYS (Notifications, Profile, Settings)
               ========================================================================= */

            // --- Notification ---
            const notifBtn = document.getElementById('notificationBtn');
            const notifDropdown = document.getElementById('notificationDropdown');
            if (notifBtn && notifDropdown) {
                notifBtn.addEventListener('click', (e) => {
                    e.stopPropagation();
                    notifDropdown.classList.toggle('hidden');
                });
                document.addEventListener('click', (e) => {
                    if (!notifDropdown.contains(e.target) && !notifBtn.contains(e.target)) notifDropdown.classList.add('hidden');
                });
            }

            // --- Profile Overlay ---
            const profileOverlay = document.getElementById("profileOverlay");
            const headerProfileBtn = document.getElementById("headerProfileBtn");
            const closeProfileBtn = document.getElementById("closeProfileOverlay");

            if (headerProfileBtn && profileOverlay) headerProfileBtn.addEventListener("click", () => profileOverlay.classList.remove("hidden"));
            if (closeProfileBtn && profileOverlay) closeProfileBtn.addEventListener("click", () => profileOverlay.classList.add("hidden"));
            if (profileOverlay) profileOverlay.addEventListener("click", (e) => {
                if (e.target === profileOverlay) profileOverlay.classList.add("hidden");
            });

            // --- Settings Menu (FIXED) ---
            const settingsBtn = document.getElementById('settingsTrigger'); // Corrected ID
            const settingsPopup = document.getElementById('settingsMenu'); // Corrected ID

            if (settingsBtn && settingsPopup) {
                settingsBtn.addEventListener('click', (e) => {
                    e.stopPropagation();
                    settingsPopup.classList.toggle('hidden');
                });
                document.addEventListener('click', (e) => {
                    if (!settingsPopup.contains(e.target) && !settingsBtn.contains(e.target)) {
                        settingsPopup.classList.add('hidden');
                    }
                });
            }

            // --- Settings Menu Accordion (Theme) ---
            const themeAccordionBtn = document.getElementById('themeAccordionBtn');
            const themeOptionsContainer = document.getElementById('themeOptionsContainer');
            const themeChevron = document.getElementById('themeChevron');

            if (themeAccordionBtn && themeOptionsContainer) {
                themeAccordionBtn.addEventListener('click', (e) => {
                    e.stopPropagation();
                    themeOptionsContainer.classList.toggle('hidden');
                    themeChevron.classList.toggle('rotate-90');
                });
            }

            // --- Logout ---
            const logoutBtn = document.getElementById('logoutBtn');
            if (logoutBtn) logoutBtn.addEventListener('click', () => window.location.href = '/auth/logout');


            /* =========================================================================
               4. CONTEST PAGE LOGIC (API INTEGRATED)
               ========================================================================= */

            // State
            let allContests = [];
            let availableProblems = [];
            let selectedProblems = [];
            let assignedData = { subjects: [], years: [], sections: [] };
            let activeTab = 'upcoming';

            // DOM Elements
            const contestListUpcoming = document.getElementById('contest-list-upcoming');
            const contestListMyContests = document.getElementById('contest-list-mycontests');
            const contestListPast = document.getElementById('contest-list-past');
            const contestFormView = document.getElementById('contest-form-view');
            const sectionManageContests = document.getElementById('section-manage-contests');
            const problemModal = document.getElementById('addProblemModal');
            const problemsTableBody = document.getElementById('available-problems-list');
            const selectedProblemsPreview = document.getElementById('selected-problems-preview');
            const selectedCountBadge = document.getElementById('selected-problems-count-badge');
            const selectedCountModal = document.getElementById('selectedProblemsCount');
            const contestPreviewModal = document.getElementById('contestPreviewModal');
            const closePreviewBtn = document.getElementById('btn-modal-close');


            // --- Initialization ---
            async function initContestPage() {
                await Promise.all([
                    fetchAssignedData(),
                    fetchContests(),
                    fetchAvailableProblems()
                ]);
                renderContests();
                
                if (closePreviewBtn && contestPreviewModal) {
                    closePreviewBtn.addEventListener('click', () => {
                        contestPreviewModal.classList.add('hidden');
                    });
                }

                const readMoreBtn = document.getElementById('readMoreBtn');
                const detDesc = document.getElementById('detDesc');
                if (readMoreBtn && detDesc) {
                    readMoreBtn.addEventListener('click', () => {
                        detDesc.classList.toggle('line-clamp-3');
                        readMoreBtn.innerHTML = detDesc.classList.contains('line-clamp-3') 
                            ? 'Read More <i class="fas fa-chevron-down text-xs"></i>' 
                            : 'Show Less <i class="fas fa-chevron-up text-xs"></i>';
                    });
                }
            }



            // --- Data Fetching ---
            async function fetchAssignedData() {
                try {
                    const res = await fetch('/hos/api/assigned-data');
                    const data = await res.json();
                    if (data.success) {
                        assignedData = data;
                        populateEligibilityFields();
                    }
                } catch (err) { console.error("Error fetching assigned data:", err); }
            }

            async function fetchContests() {
                try {
                    const res = await fetch('/hos/api/contests');
                    const data = await res.json();
                    if (data.success) {
                        allContests = data.data;
                    }
                } catch (err) { console.error("Error fetching contests:", err); }
            }

            async function fetchAvailableProblems() {
                try {
                    const res = await fetch('/hos/api/available-problems');
                    const data = await res.json();
                    if (data.success) {
                        availableProblems = data.data || [];
                    }
                } catch (err) { console.error("Error fetching problems:", err); }
            }

            // --- UI Population ---
            function populateEligibilityFields() {
                const subjectSelect = document.getElementById('eligibility-subject');
                const yearsContainer = document.getElementById('eligibility-years-container');
                const sectionsContainer = document.getElementById('eligibility-sections-container');

                if (subjectSelect) {
                    subjectSelect.innerHTML = '<option value="" disabled selected>Select Subject</option>';
                    assignedData.subjects.forEach(sub => {
                        subjectSelect.innerHTML += `<option value="${sub}">${sub}</option>`;
                    });
                }

                if (yearsContainer) {
                    yearsContainer.innerHTML = '';
                    assignedData.years.forEach(year => {
                        yearsContainer.innerHTML += `
                            <label class="flex items-center gap-2 p-1.5 hover:bg-gray-50 dark:hover:bg-gray-700/50 rounded transition-colors cursor-pointer">
                                <input type="checkbox" name="eligibility-year" value="${year}" class="rounded border-gray-300 text-primary-600 focus:ring-0">
                                <span class="text-xs text-gray-700 dark:text-gray-300 font-medium">${year}</span>
                            </label>
                        `;
                    });
                }

                if (sectionsContainer) {
                    sectionsContainer.innerHTML = '';
                    assignedData.sections.forEach(sec => {
                        sectionsContainer.innerHTML += `
                            <label class="flex items-center gap-2 p-1.5 hover:bg-gray-50 dark:hover:bg-gray-700/50 rounded transition-colors cursor-pointer">
                                <input type="checkbox" name="eligibility-section" value="${sec}" class="rounded border-gray-300 text-primary-600 focus:ring-0">
                                <span class="text-xs text-gray-700 dark:text-gray-300 font-medium">${sec}</span>
                            </label>
                        `;
                    });
                }
            }

            function renderContests() {
                const now = new Date();
                
                const upcoming = allContests.filter(c => c.status === 'upcoming' || c.status === 'accepted' || new Date(c.date) > now);
                const past = allContests.filter(c => c.status === 'past' || new Date(c.deadline) < now);
                const currentUserId = <%= user.id %>;
                const myContests = allContests.filter(c => c.createdBy === currentUserId);

                renderContestList(contestListUpcoming, upcoming, 'No upcoming contests found.');
                renderContestList(contestListPast, past, 'No past contests found.');
                renderContestList(contestListMyContests, myContests, 'No contests created yet.');
            }

            function renderContestList(container, contests, emptyMsg) {
                if (!container) return;
                container.innerHTML = '';
                
                if (contests.length === 0) {
                    container.innerHTML = `
                        <div class="col-span-full py-12 text-center bg-white dark:bg-gray-800 rounded-3xl border border-dashed border-gray-200 dark:border-gray-700">
                            <i class="fas fa-trophy text-4xl text-gray-200 dark:text-gray-700 mb-3"></i>
                            <p class="text-gray-500 dark:text-gray-400 font-medium">${emptyMsg}</p>
                        </div>
                    `;
                    return;
                }

                contests.forEach(contest => {
                    const card = createContestCard(contest);
                    container.appendChild(card);
                });
            }

            function createContestCard(contest) {
                const div = document.createElement('div');
                div.className = "bg-white dark:bg-gray-800 rounded-3xl shadow-sm border border-gray-100 dark:border-gray-700 p-6 hover:shadow-md transition-all animate-fadeIn group";
                
                const dateObj = new Date(contest.date);
                const dateStr = dateObj.toLocaleDateString();
                const timeStr = dateObj.toLocaleTimeString([], { hour: '2-digit', minute: '2-digit' });
                const deadline = new Date(contest.deadline).toLocaleString();

                
                div.innerHTML = `
                    <div class="flex flex-col md:flex-row gap-6 items-start md:items-center">
                        <div class="w-16 h-16 rounded-2xl bg-primary-50 dark:bg-primary-900/20 text-primary-600 dark:text-primary-400 flex items-center justify-center flex-shrink-0 text-2xl border border-primary-100/50 dark:border-primary-800/30">
                            <i class="fas fa-star"></i>
                        </div>
                        <div class="flex-1 min-w-0">
                            <div class="flex items-center gap-2 mb-1 flex-wrap">
                                <h3 class="text-lg font-bold text-gray-900 dark:text-white truncate uppercase">${contest.title}</h3>
                                <span class="px-2 py-0.5 rounded-full text-[10px] font-bold uppercase tracking-wider ${contest.status === 'upcoming' ? 'bg-green-100 text-green-700 dark:bg-green-900/30 dark:text-green-400' : 'bg-gray-100 text-gray-600 dark:bg-gray-700 dark:text-gray-400'}">
                                    ${contest.status}
                                </span>
                            </div>
                            <div class="flex flex-wrap items-center gap-x-4 gap-y-2 text-xs font-semibold text-gray-500 dark:text-gray-400">
                                <span class="flex items-center gap-1.5"><i class="far fa-calendar-alt text-primary-500/70"></i> ${dateStr} at ${timeStr}</span>
                                <span class="flex items-center gap-1.5"><i class="far fa-clock text-primary-500/70"></i> ${contest.duration}</span>

                                <span class="flex items-center gap-1.5"><i class="fas fa-hourglass-end text-primary-500/70"></i> Ends: ${deadline}</span>
                            </div>
                        </div>
                        <div class="flex items-center gap-2 w-full md:w-auto mt-4 md:mt-0 opacity-0 group-hover:opacity-100 transition-opacity">
                            <button onclick="viewContestDetails(${contest.id})" class="flex-1 md:flex-none p-2 rounded-xl bg-blue-50 dark:bg-blue-900/20 border border-blue-100 dark:border-blue-800 text-blue-500 hover:bg-blue-500 hover:text-white transition-all" title="View Preview">
                                <i class="fas fa-eye"></i>
                            </button>
                            <button onclick="editContest(${contest.id})" class="flex-1 md:flex-none p-2 rounded-xl bg-gray-50 dark:bg-gray-700 border border-gray-200 dark:border-gray-600 text-gray-600 dark:text-gray-300 hover:text-primary-600 dark:hover:text-primary-400 transition-colors" title="Edit">
                                <i class="fas fa-edit"></i>
                            </button>

                            <button onclick="deleteContest(${contest.id})" class="flex-1 md:flex-none p-2 rounded-xl bg-red-50 dark:bg-red-900/20 border border-red-100 dark:border-red-800 text-red-500 hover:bg-red-500 hover:text-white transition-all" title="Delete">
                                <i class="fas fa-trash-alt"></i>
                            </button>
                        </div>
                    </div>
                `;
                return div;
            }

            // --- Form Management ---
            const createContestBtn = document.getElementById('btn-create-contest');
            if (createContestBtn) {
                createContestBtn.addEventListener('click', () => {
                    sectionManageContests.classList.add('hidden');
                    contestFormView.classList.remove('hidden');
                    document.getElementById('create-contest-form').reset();
                    document.getElementById('edit-contest-id').value = '';
                    document.getElementById('form-title').textContent = "Create New Contest";
                    selectedProblems = [];
                    updateSelectedProblemsPreview();
                    window.scrollTo({ top: 0, behavior: 'smooth' });
                });
            }

            const cancelContestBtn = document.getElementById('btn-cancel-contest');
            const backToContestListBtn = document.getElementById('btn-back-to-contest-list');
            
            function closeForm() {
                contestFormView.classList.add('hidden');
                sectionManageContests.classList.remove('hidden');
            }

            if (cancelContestBtn) cancelContestBtn.addEventListener('click', closeForm);
            if (backToContestListBtn) backToContestListBtn.addEventListener('click', closeForm);

            // --- Problem Management ---
            const manageProblemsBtn = document.getElementById('btn-manage-problems');
            const closeProblemModalBtn = document.getElementById('closeAddProblemModal');
            const saveAssignedProblemsBtn = document.getElementById('btn-save-assigned-problems');

            if (manageProblemsBtn) {
                manageProblemsBtn.addEventListener('click', () => {
                    problemModal.classList.remove('hidden');
                    renderProblemTable();
                });
            }

            if (closeProblemModalBtn) {
                closeProblemModalBtn.addEventListener('click', () => {
                    problemModal.classList.add('hidden');
                });
            }

            function renderProblemTable() {
                if (!problemsTableBody) return;
                problemsTableBody.innerHTML = '';
                
                const searchTerm = document.getElementById('problemSearch').value.toLowerCase();
                const filtered = availableProblems.filter(p => 
                    p.title.toLowerCase().includes(searchTerm) || 
                    (p.subject && p.subject.toLowerCase().includes(searchTerm))
                );

                filtered.forEach(p => {
                    const isSelected = selectedProblems.some(sp => sp.id === p.id);
                    const tr = document.createElement('tr');
                    tr.className = "hover:bg-gray-50/50 dark:hover:bg-gray-900/50 transition-colors";
                    tr.innerHTML = `
                        <td class="px-6 py-4 text-center">
                            <input type="checkbox" value="${p.id}" ${isSelected ? 'checked' : ''} 
                                class="problem-cb rounded border-gray-300 text-primary-600 focus:ring-0">
                        </td>
                        <td class="px-6 py-4">
                            <div class="text-sm font-bold text-gray-900 dark:text-white">${p.title}</div>
                            <div class="text-[10px] text-gray-500 uppercase tracking-wider">${p.subject || 'All Subjects'}</div>
                        </td>
                        <td class="px-6 py-4 text-center">
                            <span class="px-2 py-0.5 rounded-full text-[10px] font-bold uppercase ${getDifficultyClass(p.difficulty)}">
                                ${p.difficulty}
                            </span>
                        </td>
                        <td class="px-6 py-4 text-center text-xs text-gray-500 dark:text-gray-400">
                            ${p.facultyName || 'HOD'}
                        </td>
                        <td class="px-6 py-4 text-center">
                            <button onclick="viewProblemDetails(${p.id})" class="p-2 text-primary-600 hover:bg-primary-50 dark:hover:bg-primary-900/20 rounded-lg transition-colors" title="View Details">
                                <i class="fas fa-eye"></i>
                            </button>
                        </td>
                    `;

                    problemsTableBody.appendChild(tr);
                });
            }

            function getDifficultyClass(d) {
                switch(d?.toLowerCase()) {
                    case 'easy': return 'bg-green-100 text-green-700 dark:bg-green-900/30 dark:text-green-400';
                    case 'medium': return 'bg-yellow-100 text-yellow-700 dark:bg-yellow-900/30 dark:text-yellow-400';
                    case 'hard': return 'bg-red-100 text-red-700 dark:bg-red-900/30 dark:text-red-400';
                    default: return 'bg-gray-100 text-gray-700 dark:bg-gray-700 dark:text-gray-300';
                }
            }

            if (saveAssignedProblemsBtn) {
                saveAssignedProblemsBtn.addEventListener('click', () => {
                    const checkboxes = document.querySelectorAll('.problem-cb:checked');
                    selectedProblems = Array.from(checkboxes).map(cb => {
                        const id = parseInt(cb.value);
                        return availableProblems.find(p => p.id === id);
                    });
                    updateSelectedProblemsPreview();
                    problemModal.classList.add('hidden');
                });
            }

            function updateSelectedProblemsPreview() {
                if (!selectedCountBadge) return;
                selectedCountBadge.textContent = selectedProblems.length;
                selectedCountModal.textContent = selectedProblems.length;

                if (!selectedProblemsPreview) return;
                selectedProblemsPreview.innerHTML = '';
                
                if (selectedProblems.length === 0) {
                    selectedProblemsPreview.innerHTML = '<p class="text-xs text-gray-500 dark:text-gray-400 text-center italic py-4">No problems selected yet.</p>';
                    return;
                }

                selectedProblems.forEach(p => {
                    const div = document.createElement('div');
                    div.className = "flex items-center justify-between p-3 rounded-xl bg-white dark:bg-gray-800 border border-gray-100 dark:border-gray-700 shadow-sm transition-all animate-fadeIn";
                    div.innerHTML = `
                        <div class="flex items-center gap-3">
                            <div class="w-8 h-8 rounded-lg bg-gray-50 dark:bg-gray-700 flex items-center justify-center text-gray-400">
                                <i class="fas fa-file-code text-xs"></i>
                            </div>
                            <div>
                                <h4 class="text-xs font-bold text-gray-800 dark:text-white">${p.title}</h4>
                                <p class="text-[10px] text-gray-500 uppercase">${p.difficulty}</p>
                            </div>
                        </div>
                        <button type="button" onclick="removeProblem(${p.id})" class="p-1.5 hover:text-red-500 transition-colors">
                            <i class="fas fa-times text-xs"></i>
                        </button>
                    `;
                    selectedProblemsPreview.appendChild(div);
                });
            }

            window.removeProblem = function(id) {
                selectedProblems = selectedProblems.filter(p => p.id !== id);
                updateSelectedProblemsPreview();
            };

            const problemSearchInput = document.getElementById('problemSearch');
            if (problemSearchInput) {
                problemSearchInput.addEventListener('input', renderProblemTable);
            }

            // --- Form Submission ---
            const contestForm = document.getElementById('create-contest-form');
            if (contestForm) {
                contestForm.addEventListener('submit', async (e) => {
                    e.preventDefault();
                    
                    const editId = document.getElementById('edit-contest-id').value;
                    const subject = document.getElementById('eligibility-subject').value;
                    const years = Array.from(document.querySelectorAll('input[name="eligibility-year"]:checked')).map(cb => cb.value);
                    const sections = Array.from(document.querySelectorAll('input[name="eligibility-section"]:checked')).map(cb => cb.value);

                    const eligibility = `${subject} | Years: ${years.join(', ')} | Sections: ${sections.join(', ')}`;

                    const title = document.getElementById('form-contest-title').value;
                    const contestDateValue = document.getElementById('form-contest-date').value;
                    const duration = document.getElementById('form-contest-duration').value;
                    const deadlineValue = document.getElementById('form-contest-deadline').value;
                    const description = document.getElementById('form-contest-desc').value;

                    if (!title || !contestDateValue || !deadlineValue) {
                        alert("Please fill in all required fields (Title, Date, and Deadline).");
                        return;
                    }

                    const contestDate = new Date(contestDateValue);
                    const deadline = new Date(deadlineValue);
                    const now = new Date();

                    if (deadline >= contestDate) {
                        alert("Registration deadline must be BEFORE the contest start time.");
                        return;
                    }

                    if (deadline <= now) {
                        alert("Registration deadline must be in the FUTURE (greater than current time).");
                        return;
                    }

                    const payload = {
                        title,
                        date: contestDateValue,
                        duration,
                        deadline: deadlineValue,
                        description,
                        eligibility,
                        problems: JSON.stringify(selectedProblems.map(p => p.id)),
                        rulesAndDescription: ""
                    };



                    try {
                        const url = editId ? `/hos/api/update-contest` : '/hos/api/create-contest';
                        const res = await fetch(url, {
                            method: 'POST',
                            headers: { 'Content-Type': 'application/json' },
                            body: JSON.stringify(payload)
                        });
                        const data = await res.json();
                        if (data.success) {
                            alert(data.message);
                            await fetchContests();
                            renderContests();
                            closeForm();
                        } else {
                            alert("Error: " + data.message);
                        }
                    } catch (err) {
                        console.error("Submission Error:", err);
                        alert("An error occurred. Please try again.");
                    }
                });
            }

            // --- Edit & Delete ---
            window.viewProblemDetails = function(id) {
                const p = availableProblems.find(item => item.id === id);
                if (!p) return;

                const content = document.getElementById('problem-details-content');
                content.innerHTML = `
                    <div class="space-y-6">
                        <div class="border-b border-gray-100 dark:border-gray-700 pb-4">
                            <div class="flex items-center gap-3 mb-2">
                                <span class="px-3 py-1 bg-primary-50 dark:bg-primary-900/20 text-primary-600 dark:text-primary-400 text-[10px] font-bold uppercase tracking-widest rounded-full">${p.subject || 'General'}</span>
                                <span class="px-3 py-1 ${getDifficultyClass(p.difficulty)} text-[10px] font-bold uppercase tracking-widest rounded-full">${p.difficulty}</span>
                            </div>
                            <h2 class="text-3xl font-extrabold text-gray-900 dark:text-white">${p.title}</h2>
                        </div>
                        
                        <div class="prose dark:prose-invert max-w-none">
                            <h4 class="text-sm font-bold text-gray-900 dark:text-white uppercase tracking-wider mb-2">Description</h4>
                            <p class="text-gray-600 dark:text-gray-400 text-sm leading-relaxed">${p.description || 'No description provided.'}</p>
                        </div>

                        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                            <div>
                                <h4 class="text-sm font-bold text-gray-900 dark:text-white uppercase tracking-wider mb-2">Input Format</h4>
                                <div class="p-4 bg-gray-50 dark:bg-gray-900/50 rounded-2xl text-xs text-gray-600 dark:text-gray-400 font-mono">${p.input_format || 'Standard Input'}</div>
                            </div>
                            <div>
                                <h4 class="text-sm font-bold text-gray-900 dark:text-white uppercase tracking-wider mb-2">Output Format</h4>
                                <div class="p-4 bg-gray-50 dark:bg-gray-900/50 rounded-2xl text-xs text-gray-600 dark:text-gray-400 font-mono">${p.output_format || 'Standard Output'}</div>
                            </div>
                        </div>

                        <div>
                            <h4 class="text-sm font-bold text-gray-900 dark:text-white uppercase tracking-wider mb-2">Constraints</h4>
                            <div class="p-4 bg-gray-50 dark:bg-gray-900/50 rounded-2xl text-xs text-gray-600 dark:text-gray-400 font-mono">${p.constraints || 'None'}</div>
                        </div>

                        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                            <div>
                                <h4 class="text-sm font-bold text-gray-900 dark:text-white uppercase tracking-wider mb-2">Sample Input</h4>
                                <pre class="p-4 bg-gray-900 text-gray-100 rounded-2xl text-xs font-mono overflow-x-auto">${p.sample_input || ''}</pre>
                            </div>
                            <div>
                                <h4 class="text-sm font-bold text-gray-900 dark:text-white uppercase tracking-wider mb-2">Sample Output</h4>
                                <pre class="p-4 bg-gray-900 text-gray-100 rounded-2xl text-xs font-mono overflow-x-auto">${p.sample_output || ''}</pre>
                            </div>
                        </div>
                    </div>
                `;
                document.getElementById('problemDetailsModal').classList.remove('hidden');
            };

            window.viewContestDetails = function(id) {
                const contest = allContests.find(c => c.id === id);
                if (!contest) return;

                document.getElementById('detFullTitle').textContent = contest.title;
                document.getElementById('detDesc').textContent = contest.description;
                document.getElementById('detEligibility').textContent = contest.eligibility;
                document.getElementById('detDuration').textContent = contest.duration;
                
                const contestDate = new Date(contest.date);
                document.getElementById('detDate').textContent = contestDate.toLocaleDateString() + ' at ' + contestDate.toLocaleTimeString([], { hour: '2-digit', minute: '2-digit' });

                
                const dead = new Date(contest.deadline);
                document.getElementById('detDay').textContent = dead.getDate();
                document.getElementById('detMonth').textContent = dead.toLocaleString('default', { month: 'short' }).toUpperCase();
                document.getElementById('detDeadlineFull').textContent = dead.toLocaleString();

                const detDesc = document.getElementById('detDesc');
                if (detDesc) detDesc.classList.add('line-clamp-3');
                const readMoreBtn = document.getElementById('readMoreBtn');
                if (readMoreBtn) readMoreBtn.innerHTML = 'Read More <i class="fas fa-chevron-down text-xs"></i>';

                document.getElementById('contestPreviewModal').classList.remove('hidden');

                
                const editBtn = document.getElementById('btn-modal-edit');
                if (editBtn) {
                    editBtn.onclick = () => {
                        document.getElementById('contestPreviewModal').classList.add('hidden');
                        editContest(id);
                    };
                }
            };

            function formatDateTimeForInput(dateString) {
                if (!dateString) return '';
                const d = new Date(dateString);
                const year = d.getFullYear();
                const month = String(d.getMonth() + 1).padStart(2, '0');
                const day = String(d.getDate()).padStart(2, '0');
                const hours = String(d.getHours()).padStart(2, '0');
                const minutes = String(d.getMinutes()).padStart(2, '0');
                return `${year}-${month}-${day}T${hours}:${minutes}`;
            }

            window.editContest = function(id) {

                const contest = allContests.find(c => c.id === id);
                if (!contest) return;

                sectionManageContests.classList.add('hidden');
                contestFormView.classList.remove('hidden');
                document.getElementById('form-title').textContent = "Edit Contest";
                document.getElementById('edit-contest-id').value = contest.id;
                
                document.getElementById('form-contest-title').value = contest.title;
                document.getElementById('form-contest-date').value = formatDateTimeForInput(contest.date);
                document.getElementById('form-contest-duration').value = contest.duration;
                document.getElementById('form-contest-deadline').value = formatDateTimeForInput(contest.deadline);
                document.getElementById('form-contest-desc').value = contest.description;


                try {
                    const parts = contest.eligibility.split('|');
                    const sub = parts[0]?.trim() || '';
                    document.getElementById('eligibility-subject').value = sub;

                    if (parts.length > 1) {
                        const yearsStr = parts[1].split(':')[1]?.trim() || '';
                        const years = yearsStr.split(', ');
                        document.querySelectorAll('input[name="eligibility-year"]').forEach(cb => cb.checked = years.includes(cb.value));
                    }
                    if (parts.length > 2) {
                        const sectionsStr = parts[2].split(':')[1]?.trim() || '';
                        const sections = sectionsStr.split(', ');
                        document.querySelectorAll('input[name="eligibility-section"]').forEach(cb => cb.checked = sections.includes(cb.value));
                    }
                } catch(e) { console.warn("Eligibility parse failed", e); }

                try {
                    const pIds = JSON.parse(contest.problems || '[]');
                    selectedProblems = availableProblems.filter(p => pIds.includes(p.id));
                    updateSelectedProblemsPreview();
                } catch(e) { selectedProblems = []; }

                window.scrollTo({ top: 0, behavior: 'smooth' });
            };


            window.deleteContest = async function(id) {
                if (!confirm("Are you sure you want to delete this contest?")) return;
                try {
                    const res = await fetch('/hos/api/delete-contest', {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify({ id })
                    });
                    const data = await res.json();
                    if (data.success) {
                        await fetchContests();
                        renderContests();
                    }
                } catch (err) { console.error("Delete Error:", err); }
            };

            // Init
            initContestPage();

            // Tabs Logic
            const tabUpcoming = document.getElementById('contest-tab-upcoming');
            const tabMyContests = document.getElementById('contest-tab-mycontests');
            const tabPast = document.getElementById('contest-tab-past');
            const listUpcoming = document.getElementById('contest-list-upcoming');
            const listMyContests = document.getElementById('contest-list-mycontests');
            const listPast = document.getElementById('contest-list-past');

            const allTabs = [tabUpcoming, tabMyContests, tabPast];
            const allLists = [listUpcoming, listMyContests, listPast];

            function switchTab(activeTabEl, activeListEl) {
                allTabs.forEach(tab => {
                    if (tab) {
                        tab.classList.remove('border-primary-500', 'text-primary-600', 'active');
                        tab.classList.add('border-transparent', 'text-gray-500');
                    }
                });
                allLists.forEach(list => list.classList.add('hidden'));

                activeTabEl.classList.add('border-primary-500', 'text-primary-600', 'active');
                activeTabEl.classList.remove('border-transparent', 'text-gray-500');
                activeListEl.classList.remove('hidden');
            }

            if (tabUpcoming) tabUpcoming.addEventListener('click', () => switchTab(tabUpcoming, listUpcoming));
            if (tabMyContests) tabMyContests.addEventListener('click', () => switchTab(tabMyContests, listMyContests));
            if (tabPast) tabPast.addEventListener('click', () => switchTab(tabPast, listPast));


        });
    </script>

    <!-- PROFILE OVERLAY -->
    <div id="profileOverlay"
        class="fixed inset-0 z-[80] flex items-center justify-center bg-black/50 backdrop-blur-sm hidden">
        <div
            class="w-[380px] bg-white dark:bg-gray-800 rounded-3xl shadow-2xl overflow-hidden animate-[fadeIn_0.2s_ease-out]">
            <div class="bg-gradient-to-br from-[#1E4A7A] to-[#153255] relative pt-12 pb-20 px-6 text-center">
                <button id="closeProfileOverlay"
                    class="absolute top-4 right-4 w-8 h-8 rounded-full bg-white/10 hover:bg-white/20 text-white/90 transition-all flex items-center justify-center backdrop-blur-sm">
                    <i class="fas fa-times text-sm"></i>
                </button>

                <div class="absolute left-1/2 bottom-[-48px] -translate-x-1/2">
                    <div
                        class="relative w-24 h-24 rounded-full p-1.5 bg-white dark:bg-gray-800 ring-4 ring-[#1E4A7A]/10 dark:ring-[#1E4A7A]/30">
                        <div
                            class="w-full h-full rounded-full bg-gradient-to-br from-blue-500 to-indigo-600 flex items-center justify-center text-white text-3xl font-bold shadow-inner">
                            <%= user.fullName.split(' ').map(n => n[0]).join('').toUpperCase().slice(0,2) %>
                        </div>
                        <div
                            class="absolute bottom-0 right-0 w-6 h-6 bg-green-500 border-4 border-white dark:border-gray-800 rounded-full">
                        </div>
                    </div>
                </div>
            </div>

            <div class="pt-16 pb-8 px-6">
                <div class="text-center mb-6">
                    <h2 class="text-2xl font-bold text-gray-900 dark:text-white mb-1"><%= user.fullName %></h2>
                    <p class="text-sm font-medium text-gray-500 dark:text-gray-400 mb-3"><%= user.post || 'Head of Department' %></p>

                    <div class="flex items-center justify-center gap-2 flex-wrap">
                        <span
                            class="px-3 py-1 rounded-full text-xs font-semibold bg-blue-50 text-blue-700 dark:bg-blue-900/30 dark:text-blue-300 border border-blue-100 dark:border-blue-800">
                            <%= user.department %> Dept
                        </span>
                        <span
                            class="px-3 py-1 rounded-full text-xs font-semibold bg-purple-50 text-purple-700 dark:bg-purple-900/30 dark:text-purple-300 border border-purple-100 dark:border-purple-800">
                            HOD
                        </span>
                    </div>
                </div>

                <div class="grid grid-cols-2 gap-4 mb-6">
                    <div
                        class="p-3 rounded-2xl bg-gray-50 dark:bg-gray-700/30 border border-gray-100 dark:border-gray-700 text-center">
                        <p class="text-xs text-gray-500 uppercase font-semibold">Faculty ID</p>
                        <p class="text-sm font-bold text-gray-800 dark:text-gray-200">FAC-<%= user.id %></p>
                    </div>
                    <div
                        class="p-3 rounded-2xl bg-gray-50 dark:bg-gray-700/30 border border-gray-100 dark:border-gray-700 text-center">
                        <p class="text-xs text-gray-500 uppercase font-semibold">Joined</p>
                        <p class="text-sm font-bold text-gray-800 dark:text-gray-200"><%= user.joiningDate || 'Aug 2023' %></p>
                    </div>
                </div>

                <div class="space-y-3">
                    <button id="logoutBtn"
                        class="w-full flex items-center justify-between p-3 rounded-xl hover:bg-red-50 dark:hover:bg-red-900/20 group transition-all duration-200 border border-transparent hover:border-red-100 dark:hover:border-red-800">
                        <div class="flex items-center gap-3">
                            <div
                                class="w-8 h-8 rounded-full bg-red-50 dark:bg-red-900/20 text-red-600 dark:text-red-400 flex items-center justify-center">
                                <i class="fas fa-sign-out-alt text-sm"></i>
                            </div>
                            <span
                                class="text-sm font-medium text-gray-700 dark:text-gray-200 group-hover:text-red-600 dark:group-hover:text-red-400">Logout</span>
                        </div>
                        <i
                            class="fas fa-chevron-right text-xs text-gray-400 group-hover:text-red-500 dark:group-hover:text-red-400"></i>
                    </button>
                </div>
            </div>
        </div>
    </div>

    <script src="/js/hos/index1_logic.js?v=1.1"></script>
</body>

</html>