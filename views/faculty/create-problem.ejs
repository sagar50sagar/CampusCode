<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Create Problem - Faculty Dashboard</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&display=swap" rel="stylesheet" />
    <script src="/js/faculty/tailwind-config.js"></script>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://cdn.quilljs.com/1.3.6/quill.snow.css" rel="stylesheet">
    
    
    <link rel="stylesheet" href="/css/faculty/style.css" />
    <script src="/js/faculty/main.js"></script>
</head>
<body class="bg-gray-50 dark:bg-gray-900 min-h-screen font-sans transition-colors duration-200">
<div class="flex h-screen overflow-hidden">
    <!-- Sidebar -->
    <%- include('../partials/faculty_nav') %>

    <div class="flex-1 overflow-y-auto">
        <%- include('../partials/faculty_header') %>

        <main class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
            <div class="bg-white dark:bg-gray-800 rounded-xl shadow-sm p-6 md:p-8 border border-gray-100 dark:border-gray-700">
                <div class="flex items-center gap-4 mb-6 border-b border-gray-200 dark:border-gray-700 pb-4">
                    <a href="/faculty/problem" class="text-gray-500 hover:text-primary-600 transition-colors">
                        <i class="fas fa-arrow-left"></i>
                    </a>
                    <h2 class="text-2xl font-bold text-gray-800 dark:text-white">Create New Problem</h2>
                </div>

                <% if (!user.isVerified) { %>
                    <div class="bg-yellow-50 dark:bg-yellow-900/30 border-l-4 border-yellow-400 p-4 mb-6 rounded-r-lg">
                        <div class="flex">
                            <div class="flex-shrink-0"><i class="fas fa-info-circle text-yellow-400"></i></div>
                            <div class="ml-3">
                                <p class="text-sm text-yellow-700 dark:text-yellow-200 font-medium">Verification Pending</p>
                                <p class="text-sm text-yellow-600 dark:text-yellow-300 mt-1">You can create problems, but they will be private until your account is verified by an admin.</p>
                            </div>
                        </div>
                    </div>
                <% } %>

                <form action="/faculty/problem/create" method="POST" id="createProblemForm" class="space-y-6">
                    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                        <div class="md:col-span-2">
                            <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">Problem Title</label>
                            <input type="text" name="title" required
                                class="w-full rounded-lg border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-700 text-sm p-3 text-gray-900 dark:text-white focus:ring-2 focus:ring-primary-500"
                                placeholder="e.g. Binary Tree Inversion">
                        </div>
                        
                        <div>
                            <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">Subject</label>
                            <select name="subject" required
                                class="w-full rounded-lg border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-700 text-sm p-3 text-gray-900 dark:text-white focus:ring-2 focus:ring-primary-500">
                                <option value="" disabled selected>Select Subject</option>
                                <% if (typeof assignedSubjects !== 'undefined' && assignedSubjects.length > 0) { %>
                                    <% assignedSubjects.forEach(function(s){ %>
                                        <option value="<%= s %>"><%= s %></option>
                                    <% }) %>
                                <% } else { %>
                                    <option value="" disabled>No subjects assigned</option>
                                <% } %>
                            </select>
                        </div>
                        
                        <div>
                            <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">Difficulty</label>
                            <select name="difficulty" required
                                class="w-full rounded-lg border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-700 text-sm p-3 text-gray-900 dark:text-white focus:ring-2 focus:ring-primary-500">
                                <option value="Easy">Easy</option>
                                <option value="Medium">Medium</option>
                                <option value="Hard">Hard</option>
                            </select>
                        </div>
                    </div>

                    <div>
                        <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">Description</label>
                        <div class="rounded-lg overflow-hidden bg-white dark:border-gray-600">
                            <div id="editor-container" class="h-64 text-gray-800"></div>
                        </div>
                        <input type="hidden" name="description" id="hiddenDescription">
                    </div>

                    <div class="grid grid-cols-1 md:grid-cols-2 gap-6 border-t border-gray-200 dark:border-gray-700 pt-6">
                        <div>
                            <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">Input Format</label>
                            <textarea name="input_format" rows="3"
                                class="w-full rounded-lg border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-700 text-sm p-3 text-gray-900 dark:text-white focus:ring-2 focus:ring-primary-500 whitespace-pre-wrap"></textarea>
                        </div>
                        <div>
                            <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">Output Format</label>
                            <textarea name="output_format" rows="3"
                                class="w-full rounded-lg border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-700 text-sm p-3 text-gray-900 dark:text-white focus:ring-2 focus:ring-primary-500 whitespace-pre-wrap"></textarea>
                        </div>
                    </div>

                    <div>
                        <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">Constraints</label>
                        <textarea name="constraints" rows="2"
                            class="w-full rounded-lg border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-700 text-sm p-3 text-gray-900 dark:text-white focus:ring-2 focus:ring-primary-500 whitespace-pre-wrap"></textarea>
                    </div>

                    <div class="grid grid-cols-1 md:grid-cols-2 gap-6 bg-gray-50 dark:bg-gray-800/50 p-4 rounded-xl border border-gray-100 dark:border-gray-700">
                        <div>
                            <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">Sample Input</label>
                            <textarea name="sample_input" rows="4" style="font-family: monospace;"
                                class="w-full rounded-lg border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-700 text-sm p-3 text-gray-900 dark:text-white focus:ring-2 focus:ring-primary-500 whitespace-pre"></textarea>
                        </div>
                        <div>
                            <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">Sample Output</label>
                            <textarea name="sample_output" rows="4" style="font-family: monospace;"
                                class="w-full rounded-lg border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-700 text-sm p-3 text-gray-900 dark:text-white focus:ring-2 focus:ring-primary-500 whitespace-pre"></textarea>
                        </div>
                    </div>

                    <div>
                        <label class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">Hidden Test Cases (JSON Array format)</label>
                        <p class="text-xs text-gray-500 mb-2">Provide a structural JSON array for automated checking. E.g. [{"input":"2 3", "output":"5"}]</p>
                        <textarea name="hidden_test_cases" rows="4" style="font-family: monospace;"
                            class="w-full rounded-lg border-gray-300 dark:border-gray-600 bg-white dark:bg-gray-700 text-sm p-3 text-gray-900 dark:text-white focus:ring-2 focus:ring-primary-500 whitespace-pre"></textarea>
                    </div>

                    <div class="flex items-center gap-2 border-t border-gray-200 dark:border-gray-700 pt-6">
                        <input type="checkbox" id="is_public" name="is_public" class="w-4 h-4 text-primary-600 rounded border-gray-300 focus:ring-primary-500" <%= !user.isVerified ? 'disabled' : '' %>>
                        <label for="is_public" class="text-sm font-medium text-gray-700 dark:text-gray-300">Set as Public (Visible to all students)</label>
                    </div>

                    <div class="flex justify-end gap-4 pt-4">
                        <a href="/faculty/problem" class="px-5 py-2.5 text-sm font-medium text-gray-700 dark:text-gray-300 bg-gray-100 dark:bg-gray-700 hover:bg-gray-200 dark:hover:bg-gray-600 rounded-lg transition-colors">Cancel</a>
                        <button type="submit" id="submitBtn" class="px-5 py-2.5 text-sm font-medium text-white bg-primary-500 hover:bg-primary-600 rounded-lg transition-colors shadow-sm">
                            Save Problem
                        </button>
                    </div>
                </form>
            </div>
        </main>
    </div>
</div>

<script src="https://cdn.quilljs.com/1.3.6/quill.js"></script>
<script>
    document.addEventListener("DOMContentLoaded", function () {
        
        applyTheme(localStorage.theme || 'system');

        var quill = new Quill('#editor-container', {
            theme: 'snow',
            placeholder: 'Problem definition, exact task requirements...',
            modules: {
                toolbar: [
                    [{ 'header': [1, 2, 3, false] }],
                    ['bold', 'italic', 'underline', 'code-block'],
                    [{ 'list': 'ordered'}, { 'list': 'bullet' }],
                    ['clean']
                ]
            }
        });

        document.getElementById('createProblemForm').onsubmit = function() {
            var html = document.querySelector('.ql-editor').innerHTML;
            document.getElementById('hiddenDescription').value = html;
        };
    });
</script>
</body>
</html>
